# ============================================================
# UTILS
# ============================================================

def tprint(msg):
    print(f"[{time.strftime('%H:%M:%S')}] {msg}", flush=True)

def safe_read_jsonl(path):
    rows = []
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            try:
                rows.append(json.loads(line))
            except:
                continue
    return rows

def write_text(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(text.strip() + "\n")

def clip_tokens(tokenizer, text, max_tokens):
    ids = tokenizer.encode(text, add_special_tokens=False)
    if len(ids) <= max_tokens:
        return text
    return tokenizer.decode(ids[-max_tokens:], skip_special_tokens=True)


def extract_summary(text):
    if "[Summary]" in text and "[/Summary]" in text:
        return text.split("[Summary]",1)[1].split("[/Summary]",1)[0].strip()
    if "[Summary]" in text:
        return text.split("[Summary]",1)[1].strip()
    return text.strip().split("\n\n")[0]

def remove_repeated_sentences(text):
    sentences = text.split(". ")
    seen = set()
    cleaned = []
    for s in sentences:
        if s.strip() and s not in seen:
            cleaned.append(s)
            seen.add(s)
    return ". ".join(cleaned)

# ============================================================
# FEW-SHOT (1 FULL EXAMPLE)
# ============================================================

def collect_one_example(root, lang, seed):
    files = list((Path(root)/lang/"Dialogues").glob("*.jsonl"))
    random.Random(seed).shuffle(files)

    for f in files:
        sum_file = Path(root)/lang/"Summary_Text"/f"{f.stem}_summary.txt"
        if not sum_file.exists():
            continue

        rows = safe_read_jsonl(f)
        dialogue = " ".join(r.get("dialogue","") for r in rows if isinstance(r,dict))
        summary = sum_file.read_text(encoding="utf-8")

        if dialogue and summary:
            return dialogue, summary

    return None, None

# ============================================================
# MODEL
# ============================================================

def load_model():
    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL)
    tokenizer.pad_token = tokenizer.eos_token

    model = AutoModelForCausalLM.from_pretrained(
        BASE_MODEL,
        device_map="auto",
        quantization_config=BitsAndBytesConfig(load_in_4bit=True),
        torch_dtype=torch.float16
    )

    model.eval()
    return model, tokenizer

# ============================================================
# GENERATION
# ============================================================

def generate_summary(model, tokenizer, prompt_text):

    prompt = f"<s>[INST] {prompt_text} [/INST]"

    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)

    output = model.generate(
        **inputs,
        max_new_tokens=MAX_NEW_TOKENS_SUMMARY,
        do_sample=False,
        temperature=0.0,
        repetition_penalty=1.1,
        pad_token_id=tokenizer.eos_token_id,
    )

    gen = output[0][inputs.input_ids.shape[-1]:]
    text = tokenizer.decode(gen, skip_special_tokens=True)

    summary = extract_summary(text)
    summary = remove_repeated_sentences(summary)

    return summary

# ============================================================
# MAIN
# ============================================================

def run():

    model, tokenizer = load_model()

    # Token budget (leave space for generation + system)
    budget = MAX_CONTEXT - MAX_NEW_TOKENS_SUMMARY - SYSTEM_OVERHEAD

    SEED = 42
    max_files_per_lang = 60

    for lang_dir in Path(TEST_DIR).iterdir():

        if lang_dir.name not in TARGET_LANGS:
            continue

        lang = lang_dir.name
        print(f"\nProcessing language: {lang}")

        dlg_dir = lang_dir / "Dialogues"
        out_dir = Path(OUTPUT_DIR) / lang / "Summary_Text"

        # ============================================================
        # RANDOM SAMPLING (FIXED)
        # ============================================================

        files = sorted(dlg_dir.glob("*.jsonl"))

        random.seed(SEED)
        random.shuffle(files)

        files = files[:min(max_files_per_lang, len(files))]

        print(f"{lang}: using {len(files)} dialogues")

        # ============================================================
        # FEW-SHOT EXAMPLE (1 FULL)
        # ============================================================

        example = collect_one_example(
            TRAIN_SPLIT_DIR, lang, FEW_SHOT_SEED
        )

        # ============================================================
        # PROCESS FILES
        # ============================================================

        for f in tqdm(files, desc=lang):

            out_file = out_dir / f"{f.stem}_summary.txt"

            if out_file.exists():
                continue

            rows = safe_read_jsonl(f)

            dialogue = " ".join(
                r.get("dialogue", "") for r in rows if isinstance(r, dict)
            )

            # Clip ONLY test dialogue
            dialogue = clip_tokens(tokenizer, dialogue, budget)

            # ============================================================
            # PROMPT
            # ============================================================

            if FEW_SHOT_K == 0 or example[0] is None:

                prompt = ZERO_SHOT_PROMPT_TEMPLATE.format(
                    dialogue=dialogue
                )

            else:
                ex_dlg, ex_sum = example

                prompt = (
                    FEW_SHOT_INSTRUCTION_HEADER
                    + "\n\nExample:\n"
                    + ex_dlg + "\n\n" + ex_sum
                    + "\n\nNow process:\n" + dialogue
                )

            # ============================================================
            # GENERATE
            # ============================================================

            summary = generate_summary(model, tokenizer, prompt)

            # ============================================================
            # SAVE
            # ============================================================

            write_text(out_file, summary)

        torch.cuda.empty_cache()

    print("\nInference completed.")

if __name__ == "__main__":
    run()
