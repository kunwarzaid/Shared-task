# ============================================================
# CONFIG
# ============================================================

BASE_MODEL = "Qwen/Qwen2.5-7B-Instruct"

TEST_DIR = "/workspace/data/KZ_2117574/SharedTask_NLPAI4Health_Train&dev_set/test"
TRAIN_SPLIT_DIR = "/workspace/data/KZ_2117574/SharedTask_NLPAI4Health_Train&dev_set/train_split"
OUTPUT_DIR = "/workspace/data/KZ_2117574/EACL/Qwen_final_fixed"

TARGET_LANGS = ["Bangla","English","Hindi","Marathi"]

FEW_SHOT_K = 1   # 0 = zero-shot, 1 = one full example
FEW_SHOT_SEED = 42

MAX_TOTAL_INPUT_TOKENS = 16384
MAX_NEW_TOKENS_SUMMARY = 1024
SYSTEM_OVERHEAD = 512

# ============================================================
# PROMPTS (SAME AS MISTRAL)
# ============================================================

ZERO_SHOT_PROMPT_TEMPLATE = """
You are a clinical documentation assistant.

Your task is to generate a clinical summary of the following doctor–patient dialogue.

STRICT RULES:
- Only use explicitly stated information
- Do NOT infer anything
- Preserve negations exactly

OUTPUT FORMAT (STRICT):

[Summary]
<final clinical summary>
[/Summary]

IMPORTANT:
- Output ONLY ONE summary
- Do NOT repeat or restate
- Stop after [/Summary]

Dialogue:
{dialogue}
"""

FEW_SHOT_INSTRUCTION_HEADER = """
You are a clinical documentation assistant.

Follow:
STEP 1: Extract facts
STEP 2: Write summary

OUTPUT FORMAT (STRICT):

[Summary]
<final clinical summary>
[/Summary]

IMPORTANT:
- Output ONLY ONE summary
- Do NOT repeat
- Stop after [/Summary]
"""

# ============================================================
# UTILS
# ============================================================

def tprint(msg):
    print(f"[{time.strftime('%H:%M:%S')}] {msg}", flush=True)

def safe_read_jsonl(path):
    rows = []
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            try:
                rows.append(json.loads(line.strip()))
            except:
                continue
    return rows

def write_text(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text.strip() + "\n", encoding="utf-8")

def clip_tokens(tokenizer, text, max_tokens):
    ids = tokenizer.encode(text, add_special_tokens=False)
    if len(ids) <= max_tokens:
        return text
    return tokenizer.decode(ids[-max_tokens:], skip_special_tokens=True)

def build_messages(user_prompt):
    return [{"role": "user", "content": user_prompt}]

# ============================================================
# CLEANING (KEY FIX)
# ============================================================

def extract_summary(text):
    if "[Summary]" in text and "[/Summary]" in text:
        return text.split("[Summary]",1)[1].split("[/Summary]",1)[0].strip()
    if "[Summary]" in text:
        return text.split("[Summary]",1)[1].strip()
    return text.strip().split("\n\n")[0]

def remove_repeated_sentences(text):
    sentences = text.split(". ")
    seen = set()
    cleaned = []
    for s in sentences:
        s_clean = s.strip()
        if s_clean and s_clean not in seen:
            cleaned.append(s_clean)
            seen.add(s_clean)
    return ". ".join(cleaned)

# ============================================================
# FEW-SHOT (1 FULL EXAMPLE)
# ============================================================

def collect_one_full_example(root, lang, seed):
    lang_dir = Path(root) / lang
    dlg_dir = lang_dir / "Dialogues"
    sum_dir = lang_dir / "Summary_Text"

    files = sorted(dlg_dir.glob("*.jsonl"))
    random.Random(seed).shuffle(files)

    for f in files:
        sum_file = sum_dir / f"{f.stem}_summary.txt"
        if not sum_file.exists():
            continue

        rows = safe_read_jsonl(f)
        dialogue = " ".join(
            r.get("dialogue", "") for r in rows if isinstance(r, dict)
        )

        summary = sum_file.read_text(encoding="utf-8", errors="replace")

        if dialogue.strip() and summary.strip():
            return dialogue.strip(), summary.strip()

    return None, None

# ============================================================
# MODEL
# ============================================================

def load_model():
    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL, use_fast=True)
    tokenizer.pad_token = tokenizer.eos_token

    quant_cfg = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_compute_dtype=torch.float16
    )

    model = AutoModelForCausalLM.from_pretrained(
        BASE_MODEL,
        device_map="auto",
        quantization_config=quant_cfg,
        dtype=torch.float16
    )

    model.eval()
    return model, tokenizer

# ============================================================
# GENERATION
# ============================================================

def chat_generate(model, tokenizer, messages):

    prompt = tokenizer.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True
    )

    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)

    with torch.no_grad():
        output = model.generate(
            **inputs,
            max_new_tokens=MAX_NEW_TOKENS_SUMMARY,
            do_sample=False,
            repetition_penalty=1.1,
            pad_token_id=tokenizer.eos_token_id
        )

    gen_ids = output[0][inputs.input_ids.shape[-1]:]
    text = tokenizer.decode(gen_ids, skip_special_tokens=True)

    summary = extract_summary(text)
    summary = remove_repeated_sentences(summary)

    return summary

# ============================================================
# MAIN PIPELINE
# ============================================================

def run_summary():

    model, tokenizer = load_model()

    dialogue_budget = (
        MAX_TOTAL_INPUT_TOKENS
        - MAX_NEW_TOKENS_SUMMARY
        - SYSTEM_OVERHEAD
    )

    langs = [
        p for p in Path(TEST_DIR).iterdir()
        if p.is_dir() and p.name in TARGET_LANGS
    ]

    for lang_dir in langs:

        lang = lang_dir.name
        tprint(f"Processing: {lang}")

        dlg_dir = lang_dir / "Dialogues"
        out_dir = Path(OUTPUT_DIR) / lang / "Summary_Text"

        files = sorted(dlg_dir.glob("*.jsonl"))[:110]

        few_example = collect_one_full_example(
            TRAIN_SPLIT_DIR, lang, FEW_SHOT_SEED
        )

        for f in tqdm(files, desc=lang):

            out_file = out_dir / f"{f.stem}_summary.txt"
            if out_file.exists():
                continue

            rows = safe_read_jsonl(f)

            dialogue = " ".join(
                r.get("dialogue", "") for r in rows if isinstance(r, dict)
            )

            dialogue_clip = clip_tokens(tokenizer, dialogue, dialogue_budget)

            # ZERO SHOT
            if FEW_SHOT_K == 0 or few_example[0] is None:
                user_prompt = ZERO_SHOT_PROMPT_TEMPLATE.format(
                    dialogue=dialogue_clip
                )

            # FEW SHOT (1 FULL EXAMPLE)
            else:
                ex_dlg, ex_sum = few_example

                user_prompt = (
                    FEW_SHOT_INSTRUCTION_HEADER
                    + "\n\nExample:\n"
                    + ex_dlg + "\n\n" + ex_sum
                    + "\n\nNow process:\n" + dialogue_clip
                )

            messages = build_messages(user_prompt)

            summary = chat_generate(model, tokenizer, messages)

            write_text(out_file, summary)

        torch.cuda.empty_cache()

    tprint("Inference completed.")

# ============================================================
# ENTRY
# ============================================================

if __name__ == "__main__":
    run_summary()
