import pandas as pd
from pathlib import Path

def audit_experiment_folders(experiment_dict):
    """
    Counts the number of summary files in each language folder for every experiment.
    Uses a dictionary to guarantee unique, clean column names.
    """
    results = []
    
    for exp_name, exp_dir in experiment_dict.items():
        exp_path = Path(exp_dir)
        if not exp_path.exists():
            print(f"Warning: Directory not found -> {exp_dir}")
            continue
            
        for lang_folder in exp_path.iterdir():
            if not lang_folder.is_dir() or lang_folder.name.startswith('.'):
                continue
                
            language = lang_folder.name
            summary_dir = lang_folder / "Summary_Text"
            
            count = 0
            if summary_dir.exists():
                count = len(list(summary_dir.glob("*_summary.txt")))
                
            results.append({
                "Language": language,
                "Experiment": exp_name,  # Uses the exact clean name from your dictionary keys
                "File_Count": count
            })
            
    # Convert to a DataFrame and create a clean pivot table
    df = pd.DataFrame(results)
    if not df.empty:
        # Rows = Languages, Columns = Experiments
        matrix = df.pivot(index="Language", columns="Experiment", values="File_Count").fillna(0).astype(int)
        print("\n=== File Count Matrix ===")
        print(matrix.to_string())
    else:
        print("No summary files found.")

