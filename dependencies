import pandas as pd
import numpy as np
import plotly.graph_objects as go
from plotly.subplots import make_subplots
import shap
from sklearn.ensemble import RandomForestRegressor

# 1. LOAD DATA
def load_and_prep_data():
    # Assuming files match your image names exactly
    demand = pd.read_csv('Demand.csv', parse_dates=['date'])
    shipments = pd.read_csv('Shipments.csv', parse_dates=['STA', 'ETA'])
    stock = pd.read_csv('Stock.csv')
    suppliers = pd.read_csv('Suppliers.csv')
    
    return demand, shipments, stock, suppliers

# 2. SIMULATE DISRUPTION & MERGE
def analyze_disruption(demand, shipments, stock, suppliers):
    # Calculate Daily Demand
    daily_demand = demand.groupby('date')['demand_quantity'].sum().reset_index()
    
    # Baseline Supply (Based on Scheduled Arrival - STA)
    baseline_supply = shipments.groupby('STA')['shipment_quantity'].sum().reset_index()
    baseline_supply.columns = ['date', 'original_supply']
    
    # Disrupted Supply (Based on Estimated Arrival - ETA)
    # We simulate the Hormuz shock by ensuring the ETAs are delayed
    disrupted_supply = shipments.groupby('ETA')['shipment_quantity'].sum().reset_index()
    disrupted_supply.columns = ['date', 'disrupted_supply']
    
    # Merge all into a Master Timeline
    master = daily_demand.merge(baseline_supply, on='date', how='left')
    master = master.merge(disrupted_supply, on='date', how='left').fillna(0)
    
    # Calculate the Gap (The "Why" we need to explain)
    master['supply_gap'] = master['demand_quantity'] - master['disrupted_supply']
    master['supply_gap'] = master['supply_gap'].clip(lower=0) # Only focus on shortages
    
    return master

# 3. GENERATE THE AUTOMATED PLOT
def plot_results(df):
    fig = make_subplots(rows=2, cols=1, shared_xaxes=True, 
                        subplot_titles=("Baseline: Original Supply vs Demand", 
                                        "With Disruption: Supply Gap Analysis"))

    # Top Plot: Original
    fig.add_trace(go.Scatter(x=df['date'], y=df['demand_quantity'], name='Demand', line=dict(color='blue')), row=1, col=1)
    fig.add_trace(go.Scatter(x=df['date'], y=df['original_supply'], name='Original Supply', line=dict(color='orange')), row=1, col=1)

    # Bottom Plot: Disruption
    fig.add_trace(go.Scatter(x=df['date'], y=df['demand_quantity'], name='Demand', line=dict(color='blue', dash='dash'), showlegend=False), row=2, col=1)
    fig.add_trace(go.Scatter(x=df['date'], y=df['disrupted_supply'], name='Disrupted Supply', line=dict(color='red')), row=2, col=1)

    fig.update_layout(height=700, title_text="Strait of Hormuz Disruption Impact", template="plotly_white")
    fig.show()

# 4. POST-HOC EXPLANATION (SHAP)
def explain_gap(df, shipments, suppliers):
    # Feature Engineering for the Explainer
    # We want to see if 'Delay Days' or 'Supplier Lead Time' caused the gap
    shipments['delay_days'] = (shipments['ETA'] - shipments['STA']).dt.days
    avg_delay = shipments.groupby('ETA')['delay_days'].mean().reset_index()
    avg_delay.columns = ['date', 'avg_delay_days']
    
    # Merge features back to master
    explain_df = df.merge(avg_delay, on='date', how='left').fillna(0)
    
    # Define Features (X) and Target (y)
    # Target: The Supply Gap
    X = explain_df[['demand_quantity', 'avg_delay_days', 'disrupted_supply']]
    y = explain_df['supply_gap']
    
    # Train Surrogate Model
    model = RandomForestRegressor(n_estimators=100)
    model.fit(X, y)
    
    # Calculate SHAP Values
    explainer = shap.TreeExplainer(model)
    shap_values = explainer.shap_values(X)
    
    print("\n--- Post-Hoc Explanation (SHAP Summary) ---")
    print("This identifies which factors 'pushed' the supply gap higher.")
    shap.summary_plot(shap_values, X, plot_type="bar")
    
    # Print localized narrative for the biggest gap
    worst_day = explain_df.loc[explain_df['supply_gap'].idxmax()]
    print(f"\n[AUTO-ANALYSIS] Greatest Disruption observed on: {worst_day['date'].date()}")
    print(f"Impact: {worst_day['supply_gap']} units missing.")
    print(f"Primary Driver: {X.columns[np.argmax(np.abs(shap_values[explain_df['supply_gap'].idxmax()]))]} was the dominant feature.")

# 5. RUN PIPELINE
if __name__ == "__main__":
    try:
        d, sh, st, su = load_and_prep_data()
        master_data = analyze_disruption(d, sh, st, su)
        plot_results(master_data)
        explain_gap(master_data, sh, su)
    except FileNotFoundError as e:
        print(f"Error: Ensure all CSV files are in the script directory. {e}")
