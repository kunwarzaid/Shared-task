def parse_clinical_jsonl(filepath):
    """Reads a multi-line JSONL file. Fault-tolerant to handle malformed JSON lines."""
    transcript = ""
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line_num, line in enumerate(f, 1):
                line = line.strip()
                if not line:
                    continue
                
                try:
                    # Try to parse it cleanly
                    data = json.loads(line)
                    speaker = data.get("speaker", "Unknown")
                    dialogue = data.get("dialogue", "")
                    transcript += f"{speaker}: {dialogue}\n"
                except json.JSONDecodeError:
                    # FALLBACK: If the JSON is broken (e.g., unescaped quotes), 
                    # just feed the raw text to GPT so we don't lose the data.
                    transcript += f"{line}\n"
                    
        return transcript
    except Exception as e:
        print(f"Error opening file {filepath}: {e}")
        return ""
