import json
import random
from pathlib import Path
from difflib import SequenceMatcher

# --- 1. CONFIGURATION ---
GT_BASE_DIR = Path("data_eval/NER_extracted/GPT")
SUMMARIES_DIR = Path("data_eval/NER_extracted/Experiment_Summaries_GPT")

# --- 2. MATCHING LOGIC (Identical to your eval script) ---
def is_match(term1, term2, threshold=0.8):
    t1, t2 = term1.lower(), term2.lower()
    if t1 in t2 or t2 in t1:
        return True
    similarity = SequenceMatcher(None, t1, t2).ratio()
    return similarity >= threshold

# --- 3. VERIFICATION DISPLAY ---
def print_verification(gt_list, pred_list, category):
    matched_gt = []
    matched_pred = []
    matches_display = []
    
    # Find Matches
    for gt_term in gt_list:
        for pred_term in pred_list:
            if pred_term not in matched_pred and is_match(gt_term, pred_term):
                matched_gt.append(gt_term)
                matched_pred.append(pred_term)
                matches_display.append(f"'{gt_term}' == '{pred_term}'")
                break
                
    # Find Hallucinations (In Prediction, not in GT)
    hallucinations = [p for p in pred_list if p not in matched_pred]
    
    # Find Omissions (In GT, not in Prediction)
    omissions = [g for g in gt_list if g not in matched_gt]
    
    print(f"\n--- [ {category.upper()} ] ---")
    print(f"📄 Ground Truth : {gt_list}")
    print(f"🤖 Summary Extra: {pred_list}")
    print("-" * 30)
    
    if matches_display:
        print("✅ MATCHES (True Positives):")
        for m in matches_display: print(f"    {m}")
    else:
        print("✅ MATCHES: None")
        
    print(f"❌ HALLUCINATED (False Positives): {hallucinations}")
    print(f"⚠️ OMITTED (False Negatives): {omissions}")


def run_verification(num_files_to_check=3):
    print("\n==================================================")
    print("   EVALUATION METRICS VERIFICATION TOOL")
    print("==================================================")
    
    # Gather all available summary files
    all_summary_files = list(SUMMARIES_DIR.rglob("*_gpt_ner.json"))
    
    if not all_summary_files:
        print("No summary files found.")
        return
        
    # Pick random files to verify
    sample_files = random.sample(all_summary_files, min(num_files_to_check, len(all_summary_files)))
    
    for summary_file in sample_files:
        case_id = summary_file.name.replace("_gpt_ner.json", "")
        language = summary_file.parent.name
        experiment = summary_file.parent.parent.name
        
        gt_lang_dir = GT_BASE_DIR / language
        gt_file = gt_lang_dir / "Extracted_JSONs" / f"{case_id}_ner.json"
        if not gt_file.exists():
            gt_file = gt_lang_dir / f"{case_id}_ner.json"
            
        if not gt_file.exists():
            continue
            
        print("\n\n==================================================")
        print(f"🔍 CASE ID   : {case_id}")
        print(f"🧪 EXPERIMENT: {experiment}")
        print(f"🌍 LANGUAGE  : {language}")
        print("==================================================")
        
        with open(summary_file, 'r', encoding='utf-8') as sf, open(gt_file, 'r', encoding='utf-8') as gf:
            summary_data = json.load(sf).get("Entities", {})
            gt_data = json.load(gf).get("GPT5_Extraction", {})
            
        categories = ["Symptoms", "Diagnoses_and_Conditions", "Substances_and_Habits", "Procedures_and_Tests", "Treatments"]
        
        for cat in categories:
            gt_list = gt_data.get(cat, []) if isinstance(gt_data, dict) else []
            pred_list = summary_data.get(cat, []) if isinstance(summary_data, dict) else []
            
            # Only print categories that actually have data to keep the terminal clean
            if gt_list or pred_list:
                print_verification(gt_list, pred_list, cat)

run_verification(3) # Change this number to see more or fewer files

