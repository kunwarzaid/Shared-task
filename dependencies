def parse_clinical_jsonl(filepath):
    """
    Reads a multi-line JSONL file where each line is an utterance.
    Concatenates them into a single readable transcript.
    """
    transcript = ""
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                if not line.strip():
                    continue
                data = json.loads(line.strip())
                speaker = data.get("speaker", "Unknown")
                dialogue = data.get("dialogue", "")
                transcript += f"{speaker}: {dialogue}\n"
        return transcript
    except Exception as e:
        print(f"Error reading JSONL: {e}")
        return ""

def extract_with_scispacy(text):
    """Runs local NER on English text to find Diseases and Drugs."""
    if not text:
        return {"DISEASE": [], "CHEMICAL": []}
        
    doc = nlp(text)
    entities = {"SYMPTOMS": [], "Diagnoses_and_Conditions": [], "Substances_and_Habits":[], "Procedures_and_Tests":[], "Treatments":[],"Patient_Context":[]}
    
    for ent in doc.ents:
        if ent.label_ in entities:
            entities[ent.label_].append(ent.text.lower())
            
    return {
        "Symptoms": list(set(entities["SYMPTOMS"])),
        "Diagnosis": list(set(entities["Diagnoses_and_Conditions"])),
        "Habits":  list(set(entities["Substances_and_Habits"])),
        "Procedures": list(set(entities["Procedures_and_Tests"])),
        "Treatment": list(set(entities["Treatments"])),
        "Patient": list(set(entities["Patient_Context"]))
    }

def extract_with_gpt5(transcript_text):
    """Uses GPT-5 to extract entities directly from the raw code-switched Indic text."""
    if not transcript_text:
        return {"DISEASE": [], "CHEMICAL": []}

    system_prompt = """
    You are a clinical data extraction assistant. Your task is to extract structured medical and contextual entities from a patient-provider dialogue transcript and output them strictly as a JSON object.

Follow these strict extraction rules:
1. Exact Extraction: Extract terms as closely to the original text as possible.
2. No Hypotheticals: Do not extract conditions, treatments, or procedures that are only discussed as possibilities or future options (e.g., do not list "cancer" under diagnoses if the doctor states "if cancer is confirmed").
3. Separation: Keep discrete concepts separate rather than clumping them together.
4. Extract entities as concise 1-3 word keywords, not full sentences.

Output your response using ONLY the following JSON schema:

{
  "Symptoms": [
    // Current physical or mental symptoms reported by the patient
  ],
  "Diagnoses_and_Conditions": [
    // Confirmed medical conditions. Do not include suspected conditions pending test results.
  ],
  "Substances_and_Habits": [
    // Consumables, lifestyle habits, or substance replacement therapies 
  ],
  "Procedures_and_Tests": [
    // Mentioned medical exams, lab work, or imaging 
  ],
  "Treatments": [
    // Medical interventions or therapies discussed 
  ]
}
    """

    try:
        response = client.chat.completions.create(
            model="gpt-5", # Replace with your specific gpt-5 model string when available
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": transcript_text}
            ],
            response_format={ "type": "json_object" },
           # temperature=0.0 # Keep temperature at 0 for deterministic extraction
        )
        return json.loads(response.choices[0].message.content)
    except Exception as e:
        print(f"GPT API Error: {e}")
        return {"DISEASE": [], "CHEMICAL": []}

