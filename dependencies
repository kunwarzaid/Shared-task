def extract_confidence(text):
    m = re.search(r"CONFIDENCE:\s*([0-9.]+)", text)
    if not m:
        return 0.0, True
    val = max(0.0, min(1.0, float(m.group(1))))
    return val, False

def extract_action(text):
    m = re.search(r"ACTION:\s*(\w+)", text)
    if m:
        return m.group(1).strip()

    text_lower = text.lower()
    
    if "ask" in text_lower or "question" in text_lower or "gather" in text_lower:
        return "ask_question"
    if "prescri" in text_lower:
        return "prescribe_medication"
    if "admit" in text_lower:
        return "admit_patient"
    if ("order" in text_lower or "request" in text_lower) and (
        "imaging" in text_lower or "mri" in text_lower or "ct" in text_lower
        or "x-ray" in text_lower or "xray" in text_lower
    ):
        return "order_imaging"
    if ("order" in text_lower or "request" in text_lower) and (
        "lab" in text_lower or "blood" in text_lower or "test" in text_lower
    ):
        return "order_lab_test"
    if "discharge" in text_lower:
        return "discharge"
    if "follow" in text_lower:
        return "advise_followup"
    if "refer" in text_lower:
        return "refer_specialist"

    return "ask_question"  # Safe conversational default

def extract_diagnosis(text):
    m = re.search(r"DIAGNOSIS:\s*(.*)", text)
    return m.group(1).strip() if m else "unknown"

def extract_requested_tests(doctor_output):
    """Extract all REQUEST_TEST lines from doctor output."""
    tests = re.findall(r"REQUEST_TEST:\s*(.+)", doctor_output)
    return [t.strip() for t in tests]

# ============================================================
# GUARDRAILS
# ============================================================

def harm_score(action):
    return {
        "discharge": 4,
        "prescribe_high_risk_medication": 4,
        "prescribe_medication": 3,
        "admit_patient": 2,
        "order_imaging": 2,
        "order_lab_test": 1,
        "refer_specialist": 1,
        "advise_followup": 1,
        "ask_question": 0,
        "REVIEW": 0, # Note: Set to 1 if you want to penalize operational friction
    }.get(action, 0)

def is_unsafe(action, confidence, text, diagnosis, turn_number=1):
    # Don't apply guardrail on the very first conversational turn
    if turn_number <= 1:
        return False
        
    unsafe_actions = ["discharge", "prescribe_high_risk_medication", "advise_followup", "refer_specialist"]
    
    if action in unsafe_actions and confidence < 0.6:
        return True
    if action in unsafe_actions and diagnosis == "unknown":
        return True
    if confidence > 0.85 and any(w in text.lower() for w in ["possible", "likely"]):
        return True
    return False

def apply_guardrail(action, confidence, text, diagnosis, turn_number=1):
    return "REVIEW" if is_unsafe(action, confidence, text, diagnosis, turn_number) else action

