def parse_clinical_jsonl(filepath):
    """Indestructible file reader. Parses JSON if valid, falls back to raw text if broken."""
    transcript = ""
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            lines = f.readlines()
            
        if not lines:
            print(f"  [WARNING] The file is physically empty: {filepath}")
            return ""
            
        for line in lines:
            line = line.strip()
            if not line:
                continue
            
            try:
                # Attempt strict JSON parsing
                data = json.loads(line)
                speaker = data.get("speaker", "Unknown")
                dialogue = data.get("dialogue", "")
                transcript += f"{speaker}: {dialogue}\n"
            except Exception:
                # FALLBACK: If JSON is broken, just append the raw line text so we don't lose data!
                # We do a quick string replace to make the broken JSON slightly more readable for GPT
                clean_line = line.replace('{"speaker":', 'Speaker:').replace('"dialogue":', '->')
                transcript += f"{clean_line}\n"
                
        return transcript
        
    except Exception as e:
        print(f"  [FATAL ERROR] Could not open file {filepath}: {e}")
        return ""
