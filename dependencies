import shutil
from pathlib import Path

def create_union_test_set(original_test_dir, experiment_dirs, output_dir):
    """
    Finds dialogues present in AT LEAST ONE experiment and copies them to a new filtered test folder.
    """
    orig_test_path = Path(original_test_dir)
    output_path = Path(output_dir)
    
    # Iterate through each language folder in the original Test directory
    for lang_folder in orig_test_path.iterdir():
        if not lang_folder.is_dir():
            continue
            
        language = lang_folder.name
        orig_dialogues_dir = lang_folder / "Dialogues"
        
        if not orig_dialogues_dir.exists():
            continue

        # 1. Get the base set of all Case IDs in the original Test folder
        source_case_ids = {f.name.replace(".jsnol", "") for f in orig_dialogues_dir.glob("*.jsnol")}
        
        # 2. Build a master pool of Case IDs from ALL experiments for this language
        all_experiment_cases = set()
        
        for exp_dir in experiment_dirs:
            exp_summary_dir = Path(exp_dir) / language / "Summary"
            
            if exp_summary_dir.exists():
                # Extract 'case_123' from 'case_123_summary.txt'
                exp_cases = {f.name.replace("_summary.txt", "") for f in exp_summary_dir.glob("*_summary.txt")}
                
                # Add these cases to our master pool (Union)
                all_experiment_cases.update(exp_cases)

        # 3. Filter: Keep cases that exist in the source folder AND our master experiment pool
        valid_case_ids = source_case_ids.intersection(all_experiment_cases)

        # 4. Copy the surviving dialogues to the new Filtered Test folder
        if valid_case_ids:
            dest_dialogues_dir = output_path / language / "Dialogues"
            dest_dialogues_dir.mkdir(parents=True, exist_ok=True)
            
            copied_count = 0
            for case_id in valid_case_ids:
                src_file = orig_dialogues_dir / f"{case_id}.jsnol"
                dest_file = dest_dialogues_dir / f"{case_id}.jsnol"
                
                if src_file.exists():
                    shutil.copy2(src_file, dest_file)
                    copied_count += 1
            
            print(f"[{language}] Copied {copied_count} dialogues (present in >= 1 experiment).")
        else:
            print(f"[{language}] No matching dialogues found in any experiment. Skipped.")

# ==========================================
# Execution Setup
# ==========================================

SOURCE_TEST_FOLDER = "Test"
FILTERED_TEST_FOLDER = "Filtered_Test_For_Translation"

EXPERIMENT_FOLDERS = [
    "Mistral_zeroshot",
    "Mistral_fewshot",
    "Mistral_finetuned",
    "Mistral_translation"
]

print("Starting union filter...\n")
create_union_test_set(
    original_test_dir=SOURCE_TEST_FOLDER,
    experiment_dirs=EXPERIMENT_FOLDERS,
    output_dir=FILTERED_TEST_FOLDER
)
print("\nDone! Dialogues appearing in at least one experiment have been copied.")
