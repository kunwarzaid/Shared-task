import pandas as pd
from pathlib import Path

def match_experiment_files(experiment_name, test_base_dir, exp_base_dir):
    """Matches dialogue and summary files across 10 language subfolders."""
    test_base_path = Path(test_base_dir)
    exp_base_path = Path(exp_base_dir)
    
    matched_pairs = []

    # Iterate through each language folder in the test directory
    for lang_folder in test_base_path.iterdir():
        # Skip if it's not a directory (e.g., hidden files)
        if not lang_folder.is_dir():
            continue
            
        language = lang_folder.name
        
        # Construct the path to the 'Dialogues' subfolder for this language
        dialogue_dir = lang_folder / "Dialogues"
        
        # Construct the expected path to the matching language folder in the experiments directory
        exp_lang_folder = exp_base_path / language
        
        if not exp_lang_folder.exists():
            print(f"Warning: Missing language folder '{language}' in {experiment_name} directory.")
            continue

        # Use rglob (recursive glob) to find summary files. 
        # This safely catches them whether they are directly in the language folder 
        # or nested inside an additional subfolder (like /Hindi/Summaries/)
        for summary_path in exp_lang_folder.rglob("*_summary.txt"):
            
            # Isolate the base name
            base_name = summary_path.name.replace("_summary.txt", "")
            
            # Construct the expected source dialogue filename
            dialogue_filename = f"{base_name}.jsnol" 
            dialogue_path = dialogue_dir / dialogue_filename
            
            # Fallback check in case some files use the standard .jsonl extension
            if not dialogue_path.exists():
                alt_dialogue_path = dialogue_dir / f"{base_name}.jsonl"
                if alt_dialogue_path.exists():
                    dialogue_path = alt_dialogue_path
            
            # Verify the matching source file exists
            if dialogue_path.exists():
                matched_pairs.append({
                    "Language": language, # Added to track language per case
                    "Case_ID": base_name,
                    "Dialogue_File": str(dialogue_path),
                    "Summary_File": str(summary_path)
                })
            else:
                print(f"Warning: Missing source file for {summary_path.name} in {language}. Expected {dialogue_filename}")

    # Convert the valid matches into a Pandas DataFrame
    df_log = pd.DataFrame(matched_pairs)
    
    # Save to a dedicated CSV named after the experiment
    output_filename = f"{experiment_name}_matched_files.csv"
    
    if not df_log.empty:
        df_log.to_csv(output_filename, index=False)
        print(f"[{experiment_name}] Successfully mapped {len(df_log)} file pairs across {len(df_log['Language'].unique())} languages. Saved to '{output_filename}'")
    else:
        print(f"[{experiment_name}] No matches found. CSV not created.")

