if __name__ == "__main__":
    dataset = load_jsonl("agentclinic_medqa.jsonl")
    logs = run_experiment(dataset)
    metrics = compute_metrics(logs)

    print("\n===== FINAL METRICS =====")
    for k, v in metrics.items():
        print(f"{k}: {v}")

    save_csv(logs)
