import pandas as pd

def add_explanations(fig, ranga_data, shipments_df):
    try:
        geo_info = ranga_data['affected_geographies'][0]
        start_date = pd.to_datetime(geo_info['impact_start_date'])
        end_date = pd.to_datetime(geo_info['expected_impact_end_date'])
    except:
        return fig

    # --- STEP 1: DETECT THE SIMULATION RULES ---
    # We look at the actual data result to find the 'hidden' delay rules
    if 'CURR_ETA' in shipments_df.columns and 'STA' in shipments_df.columns:
        # Calculate how many days each shipment was actually pushed
        shipments_df['actual_delay'] = (pd.to_datetime(shipments_df['CURR_ETA']) - 
                                        pd.to_datetime(shipments_df['STA'])).dt.days
        
        # Filter for the shipments that were delayed (> 0 days)
        impacted = shipments_df[shipments_df['actual_delay'] > 0]['actual_delay']
        
        # We find the min/max from the actual data generated by their class
        low = int(impacted.min()) if not impacted.empty else 7
        high = int(impacted.max()) if not impacted.empty else 15
    else:
        # Fallback if the dataframe hasn't been processed yet
        low, high = 7, 15

    # --- STEP 2: FIND THE PEAK (The "Bullwhip" Spike) ---
    # We scan the Plotly figure data to find the exact peak date after the window
    spike_date = end_date.strftime('%Y-%m-%d')
    for trace in fig.data:
        if trace.name == "Disrupted Supply" and trace.visible is True:
            df_trace = pd.DataFrame({'date': pd.to_datetime(trace.x), 'qty': trace.y})
            post_window = df_trace[df_trace['date'] > end_date]
            if not post_window.empty:
                # Point to the mathematical maximum
                spike_date = post_window.loc[post_window['qty'].idxmax()]['date'].strftime('%Y-%m-%d')
            break

    # --- STEP 3: ADD ANNOTATIONS ---
    # 1. The Shortfall Explanation
    fig.add_annotation(
        x=start_date.strftime('%Y-%m-%d'), y=0.3, xref="x", yref="y2 domain",
        text=f"<b>Shortfall Onset:</b><br>{low}-{high} day carrier delays<br>applied to all orders here.",
        showarrow=True, arrowhead=2, arrowcolor="#DC2626", ax=-70, ay=-40,
        font=dict(color="#F1F5F9", size=11), bgcolor="#1E293B", bordercolor="#DC2626"
    )

    # 2. The Spike Explanation (The Convergence)
    fig.add_annotation(
        x=spike_date, y=0.8, xref="x", yref="y2 domain",
        text="<b>Inventory Spike:</b><br>Delayed backlog arriving<br>with normal schedule.",
        showarrow=True, arrowhead=2, arrowcolor="#059669", ax=80, ay=-50,
        font=dict(color="#F1F5F9", size=11), bgcolor="#1E293B", bordercolor="#059669"
    )

    return fig
