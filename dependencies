import json
from pathlib import Path
from openai import AzureOpenAI

# --- 1. CONFIGURATION ---
GT_BASE_DIR = Path("data_eval/NER_extracted/GPT")
SUMMARIES_DIR = Path("data_eval/NER_extracted/Experiment_Summaries_GPT")
OUTPUT_DIR = Path("data_eval/NER_extracted/LLM_Judge_Verdicts/Translated")

# ADDED: Only process these specific experiment folders
TARGET_EXPERIMENTS = [
    "Mistral_Translated",
    "Qwen_Translated"
]

endpoint = "https://ctonpncuaaiopenai.openai.azure.com/"
model_name = "gpt-5"
deployment = "gpt-5"
subscription_key = "YOUR_API_KEY_HERE"  # Add your Azure key here
api_version = "2024-12-01-preview"

client = AzureOpenAI(
    api_version=api_version,
    azure_endpoint=endpoint,
    api_key=subscription_key,
)

# --- 2. HELPER FUNCTIONS ---
def count_entities(data_dict):
    """Counts the total number of items across all extracted lists."""
    if not isinstance(data_dict, dict):
        return 0
    return sum(len(v) for v in data_dict.values() if isinstance(v, list))

def call_llm_judge(ground_truth_json, summary_json):
    system_prompt = """
    You are an expert clinical auditor evaluating the performance of a medical AI system.
    You will be provided with:
    1. A 'Ground Truth' JSON representing the exact facts from a clinical encounter.
    2. A 'Summary Output' JSON representing what an AI system extracted from a summary.

    Your job is to compare the two and identify clinical discrepancies. Account for clinical synonyms (e.g., 'Hypertension' = 'High Blood Pressure', or 'hydration' = 'stay hydrated').
    
    Output your findings strictly using this JSON schema. Ensure your integer counts perfectly match the number of items in your arrays!
    {
        "Clinical_Hallucinations": ["List any items in the Summary Output that are NOT supported by the Ground Truth."],
        "Clinical_Omissions": ["List any critical items in the Ground Truth that the Summary Output FAILED to include."],
        "Valid_Matches": ["List items correctly identified in both (show as 'SummaryTerm == GT_Term')."],
        "Total_Hallucination_Count": <integer count of the Clinical_Hallucinations array>,
        "Total_Omission_Count": <integer count of the Clinical_Omissions array>
    }
    """
    
    user_prompt = f"GROUND TRUTH:\n{json.dumps(ground_truth_json)}\n\nSUMMARY OUTPUT:\n{json.dumps(summary_json)}"

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            response_format={ "type": "json_object" },
            temperature=0.0
        )
        return json.loads(response.choices[0].message.content)
    except Exception as e:
        print(f"API Error: {e}")
        return None

# --- 3. EXECUTION ---
def run_llm_judge():
    print("\n--- Starting LLM-as-a-Judge Evaluation (Translated Only) ---")
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    
    skipped_files = 0
    
    for exp_folder in SUMMARIES_DIR.iterdir():
        if not exp_folder.is_dir() or exp_folder.name.startswith('.'): continue
        experiment_name = exp_folder.name
        
        # ADDED: Filter out experiments not in our target list
        if experiment_name not in TARGET_EXPERIMENTS:
            continue
            
        print(f"\n==================================================")
        print(f"   Processing Target Experiment: {experiment_name}")
        print(f"==================================================")
        
        for lang_folder in exp_folder.iterdir():
            if not lang_folder.is_dir() or lang_folder.name.startswith('.'): continue
            language = lang_folder.name
            
            gt_lang_dir = GT_BASE_DIR / language
            dest_lang_dir = OUTPUT_DIR / experiment_name / language
            dest_lang_dir.mkdir(parents=True, exist_ok=True)
            
            files_to_process = list(lang_folder.glob("*_gpt_ner.json"))
            if not files_to_process: continue
            
            print(f"[{experiment_name} | {language}] Judging {len(files_to_process)} cases...")
            
            for count, summary_file in enumerate(files_to_process, 1):
                case_id = summary_file.name.replace("_gpt_ner.json", "")
                output_file = dest_lang_dir / f"{case_id}_judge.json"
                
                if output_file.exists(): continue # Crash recovery is active
                
                # Locate GT
                gt_file = gt_lang_dir / "Extracted_JSONs" / f"{case_id}_ner.json"
                if not gt_file.exists():
                    gt_file = gt_lang_dir / f"{case_id}_ner.json"
                
                if not gt_file.exists(): continue
                    
                with open(summary_file, 'r', encoding='utf-8') as sf, open(gt_file, 'r', encoding='utf-8') as gf:
                    summary_data = json.load(sf).get("Entities", {})
                    gt_data = json.load(gf).get("GPT5_Extraction", {})
                
                # --- PRE-FLIGHT SANITY CHECK ---
                total_gt = count_entities(gt_data)
                total_summary = count_entities(summary_data)
                
                if total_gt == 0 or total_summary == 0:
                    print(f"  [SKIPPED] {case_id} contains no entities. GT: {total_gt}, Summary: {total_summary}")
                    skipped_files += 1
                    continue
                # -------------------------------

                judge_verdict = call_llm_judge(gt_data, summary_data)
                
                if judge_verdict:
                    final_record = {
                        "Case_ID": case_id,
                        "Experiment": experiment_name,
                        "Language": language,
                        "Judge_Verdict": judge_verdict
                    }
                    with open(output_file, 'w', encoding='utf-8') as out:
                        json.dump(final_record, out, indent=4)
                        
                if count % 10 == 0:
                    print(f"  ...judged {count}/{len(files_to_process)}")

    print("\n==================================================")
    print(f"LLM-as-a-Judge Pipeline Complete!")
    print(f"Skipped {skipped_files} gibberish/empty files to save costs.")
    print("==================================================")

run_llm_judge()


