import json
from pathlib import Path
from openai import AzureOpenAI

# --- 1. CONFIGURATION ---
# IMPORTANT: Point this to the new folder containing the raw .jsonl conversation files
RAW_GT_DIR = Path("data_eval/YOUR_NEW_TEST_FOLDER_NAME_HERE") 

SUMMARIES_DIR = Path("data_eval/NER_extracted/Experiment_Summaries_GPT")
OUTPUT_DIR = Path("data_eval/NER_extracted/LLM_Judge_Verdicts/Translated_FastTrack")

TARGET_EXPERIMENTS = [
    "Mistral_Translated",
    "Qwen_Translated"
]

endpoint = "https://ctonpncuaaiopenai.openai.azure.com/"
deployment = "gpt-5"
subscription_key = ""  # Add your Azure key here
api_version = "2024-12-01-preview"

client = AzureOpenAI(
    api_version=api_version,
    azure_endpoint=endpoint,
    api_key=subscription_key,
)

# --- 2. HELPER FUNCTIONS ---
def extract_conversation_from_jsonl(filepath):
    """Reconstructs the full Patient-Doctor conversation from the JSONL file."""
    dialogue_parts = []
    try:
        with open(filepath, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                try:
                    r = json.loads(line.strip())
                    speaker = r.get("speaker", "Unknown")
                    # Safely grab either the English translation or the native dialogue
                    text = r.get("translated_dialogue", r.get("dialogue", ""))
                    if text:
                        dialogue_parts.append(f"{speaker}: {text}")
                except:
                    continue
                    
        conversation_text = "\n".join(dialogue_parts)
        return conversation_text
    except Exception as e:
        print(f"Error reading JSONL: {e}")
    return None

def call_llm_judge_direct(conversation_text, summary_json):
    system_prompt = """
    You are an expert clinical auditor evaluating a medical AI system.
    You will be provided with:
    1. A 'Ground Truth Conversation' (the raw, actual transcript of the doctor-patient encounter).
    2. An 'AI Extracted Entities' JSON representing the medical facts an AI generated based on a summary of this encounter.

    Your job is to compare the AI's JSON entities directly against the Ground Truth Conversation. Account for clinical synonyms (e.g., 'Hypertension' = 'High Blood Pressure').
    
    Output your findings strictly using this JSON schema. Ensure your integer counts match your arrays perfectly!
    {
        "Clinical_Hallucinations": ["List entities in the AI JSON that were NEVER mentioned or implied in the Ground Truth Conversation."],
        "Clinical_Omissions": ["List critical medical facts (symptoms, diagnoses, treatments) discussed in the Conversation that are MISSING from the AI JSON."],
        "Valid_Matches": ["List items correctly identified in both."],
        "Total_Hallucination_Count": <integer count of the Clinical_Hallucinations array>,
        "Total_Omission_Count": <integer count of the Clinical_Omissions array>
    }
    """
    
    user_prompt = f"GROUND TRUTH CONVERSATION:\n{conversation_text}\n\nAI EXTRACTED ENTITIES (JSON):\n{json.dumps(summary_json)}"

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            response_format={ "type": "json_object" },
            temperature=0.0
        )
        return json.loads(response.choices[0].message.content)
    except Exception as e:
        print(f"API Error: {e}")
        return None

# --- 3. EXECUTION ---
def run_fast_llm_judge():
    print("\n--- Starting FAST-TRACK LLM-as-a-Judge Evaluation ---")
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    
    for exp_folder in SUMMARIES_DIR.iterdir():
        if not exp_folder.is_dir() or exp_folder.name.startswith('.') or exp_folder.name not in TARGET_EXPERIMENTS: 
            continue
            
        experiment_name = exp_folder.name
        print(f"\n==================================================")
        print(f"   Processing: {experiment_name}")
        print(f"==================================================")
        
        for lang_folder in exp_folder.iterdir():
            if not lang_folder.is_dir() or lang_folder.name.startswith('.'): continue
            language = lang_folder.name
            
            # The new GT directory structure
            gt_lang_dir = RAW_GT_DIR / language / "Dialogues"
            if not gt_lang_dir.exists():
                gt_lang_dir = RAW_GT_DIR / language # Fallback
            
            dest_lang_dir = OUTPUT_DIR / experiment_name / language
            dest_lang_dir.mkdir(parents=True, exist_ok=True)
            
            files_to_process = list(lang_folder.glob("*_gpt_ner.json"))
            if not files_to_process: continue
                
            print(f"[{experiment_name} | {language}] Judging {len(files_to_process)} cases...")
            
            for count, summary_file in enumerate(files_to_process, 1):
                # Clean up the case ID
                case_id = summary_file.name.replace("_gpt_ner.json", "").replace("_summary", "")
                
                output_file = dest_lang_dir / f"{case_id}_judge.json"
                if output_file.exists(): continue 
                
                # 1. Locate Raw Ground Truth .jsonl
                gt_file = gt_lang_dir / f"{case_id}.jsonl"
                
                if not gt_file.exists():
                    print(f"  ❌ MISSING GT: Could not find raw JSONL for Case ID: {case_id}")
                    continue
                    
                # 2. Extract Data
                conversation_text = extract_conversation_from_jsonl(gt_file)
                with open(summary_file, 'r', encoding='utf-8') as sf:
                    summary_json_content = json.load(sf)
                    summary_data = summary_json_content.get("Entities", {})
                
                if not conversation_text or len(conversation_text.strip()) < 10:
                    print(f"  ⚠️ EMPTY CONVERSATION: File {gt_file.name}")
                    continue

                # 3. Call Direct Judge
                judge_verdict = call_llm_judge_direct(conversation_text, summary_data)
                
                if judge_verdict:
                    final_record = {
                        "Case_ID": case_id,
                        "Experiment": experiment_name,
                        "Language": language,
                        "Judge_Verdict": judge_verdict
                    }
                    with open(output_file, 'w', encoding='utf-8') as out:
                        json.dump(final_record, out, indent=4)
                        
                if count % 10 == 0:
                    print(f"  ...judged {count}/{len(files_to_process)}")

run_fast_llm_judge()


