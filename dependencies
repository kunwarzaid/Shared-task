TARGET_LANGS = ["Gujarati"]

FEW_SHOT_K = 0   # 0 = Zero-shot, 1 = Few-shot (FULL example)
FEW_SHOT_SEED = 42

MAX_CONTEXT = 16384
MAX_NEW_TOKENS_SUMMARY = 1024
SYSTEM_OVERHEAD = 512

# ============================================================
