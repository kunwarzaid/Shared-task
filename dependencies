import pandas as pd
from pathlib import Path

def match_experiment_files(experiment_name, dialogue_dir_path, summary_dir_path):
    """Matches dialogue and summary files for a specific experiment and saves a dedicated CSV."""
    dialogue_dir = Path(dialogue_dir_path)
    summary_dir = Path(summary_dir_path)
    
    matched_pairs = []

    # Iterate through all text files ending in '_summary.txt' in this specific experiment's folder
    for summary_path in summary_dir.glob("*_summary.txt"):
        
        # Isolate the base name (e.g., 'case_001' from 'case_001_summary.txt')
        base_name = summary_path.name.replace("_summary.txt", "")
        
        # Construct the expected source dialogue filename (.jsnol as specified)
        dialogue_filename = f"{base_name}.jsnol" 
        dialogue_path = dialogue_dir / dialogue_filename
        
        # Verify the matching source file exists
        if dialogue_path.exists():
            matched_pairs.append({
                "Case_ID": base_name,
                "Dialogue_File": str(dialogue_path),
                "Summary_File": str(summary_path)
            })
        else:
            print(f"Warning: Missing source file for {summary_path.name} in {experiment_name}. Expected {dialogue_filename}")

    # Convert the valid matches into a Pandas DataFrame
    df_log = pd.DataFrame(matched_pairs)
    
    # Save to a dedicated CSV named after the experiment
    output_filename = f"{experiment_name}_matched_files.csv"
    
    if not df_log.empty:
        df_log.to_csv(output_filename, index=False)
        print(f"[{experiment_name}] Successfully mapped {len(df_log)} file pairs. Saved to '{output_filename}'")
    else:
        print(f"[{experiment_name}] No matches found. CSV not created.")

