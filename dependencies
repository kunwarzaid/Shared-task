import json
import random
from pathlib import Path
from openai import AzureOpenAI

# --- 1. CONFIGURATION ---
GT_BASE_DIR = Path("data_eval/NER_extracted/GPT")
SUMMARIES_DIR = Path("data_eval/NER_extracted/Experiment_Summaries_GPT")

endpoint = "https://ctonpncuaaiopenai.openai.azure.com/"
model_name = "gpt-5"
deployment = "gpt-5"
subscription_key = "YOUR_API_KEY_HERE"  # Add your Azure key here
api_version = "2024-12-01-preview"

client = AzureOpenAI(
    api_version=api_version,
    azure_endpoint=endpoint,
    api_key=subscription_key,
)

# --- 2. HELPER FUNCTIONS ---
def count_entities(data_dict):
    if not isinstance(data_dict, dict): return 0
    return sum(len(v) for v in data_dict.values() if isinstance(v, list))

def call_llm_judge(ground_truth_json, summary_json):
    system_prompt = """
    You are an expert clinical auditor evaluating the performance of a medical AI system.
    You will be provided with:
    1. A 'Ground Truth' JSON representing the exact facts from a clinical encounter.
    2. A 'Summary Output' JSON representing what an AI system extracted from a summary.

    Your job is to compare the two and identify clinical discrepancies. Account for clinical synonyms (e.g., 'Hypertension' = 'High Blood Pressure', or 'hydration' = 'stay hydrated').
    
    Output your findings strictly using this JSON schema:
    {
        "Clinical_Hallucinations": ["List any items in the Summary Output that are NOT supported by the Ground Truth."],
        "Clinical_Omissions": ["List any critical items in the Ground Truth that the Summary Output FAILED to include."],
        "Valid_Matches": ["List items correctly identified in both (show as 'SummaryTerm == GT_Term')."],
        "Total_Hallucination_Count": 0,
        "Total_Omission_Count": 0
    }
    """
    user_prompt = f"GROUND TRUTH:\n{json.dumps(ground_truth_json, indent=2)}\n\nSUMMARY OUTPUT:\n{json.dumps(summary_json, indent=2)}"

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            response_format={ "type": "json_object" },
            temperature=0.0
        )
        return json.loads(response.choices[0].message.content)
    except Exception as e:
        print(f"API Error: {e}")
        return None

# --- 3. EXECUTION ---
def run_test_drive(num_cases=2):
    print("\n==================================================")
    print("   LLM JUDGE TEST DRIVE & VERIFICATION TOOL")
    print("==================================================")
    
    all_summary_files = list(SUMMARIES_DIR.rglob("*_gpt_ner.json"))
    if not all_summary_files:
        print("No summary files found.")
        return
        
    random.shuffle(all_summary_files)
    cases_tested = 0
    
    for summary_file in all_summary_files:
        if cases_tested >= num_cases:
            break
            
        case_id = summary_file.name.replace("_gpt_ner.json", "")
        language = summary_file.parent.name
        experiment = summary_file.parent.parent.name
        
        gt_lang_dir = GT_BASE_DIR / language
        gt_file = gt_lang_dir / "Extracted_JSONs" / f"{case_id}_ner.json"
        if not gt_file.exists():
            gt_file = gt_lang_dir / f"{case_id}_ner.json"
            
        if not gt_file.exists():
            continue
            
        with open(summary_file, 'r', encoding='utf-8') as sf, open(gt_file, 'r', encoding='utf-8') as gf:
            summary_data = json.load(sf).get("Entities", {})
            gt_data = json.load(gf).get("GPT5_Extraction", {})
            
        # Skip gibberish files
        if count_entities(gt_data) == 0 or count_entities(summary_data) == 0:
            continue
            
        print(f"\n\n🔍 Evaluating: {case_id} | {experiment} | {language}")
        print("Waiting for LLM Judge to process...\n")
        
        verdict = call_llm_judge(gt_data, summary_data)
        
        if verdict:
            print(f"--- 📄 RAW GROUND TRUTH INPUT ---")
            for k, v in gt_data.items():
                if v: print(f"  {k}: {v}")
                
            print(f"\n--- 🤖 RAW SUMMARY OUTPUT INPUT ---")
            for k, v in summary_data.items():
                if v: print(f"  {k}: {v}")
                
            print("\n==================================================")
            print("⚖️   LLM JUDGE VERDICT")
            print("==================================================")
            print("✅ VALID MATCHES:")
            for m in verdict.get("Valid_Matches", []): print(f"   - {m}")
                
            print("\n❌ HALLUCINATIONS (False Positives):")
            for h in verdict.get("Clinical_Hallucinations", []): print(f"   - {h}")
                
            print("\n⚠️ OMISSIONS (False Negatives):")
            for o in verdict.get("Clinical_Omissions", []): print(f"   - {o}")
                
            print(f"\n📊 COUNTS -> Hallucinations: {verdict.get('Total_Hallucination_Count', 0)} | Omissions: {verdict.get('Total_Omission_Count', 0)}")
            print("==================================================")
            
            cases_tested += 1

run_test_drive(2)

