import pandas as pd
import numpy as np

def add_explanations(fig, ranga_data, shipments_df):
    """
    Analyzes the shipment data and plot traces to provide 
    dynamic, data-driven explainability annotations.
    """
    try:
        geo_info = ranga_data['affected_geographies'][0]
        start_date = pd.to_datetime(geo_info['impact_start_date'])
        end_date = pd.to_datetime(geo_info['expected_impact_end_date'])
        severity = geo_info.get('impact_level', 'HIGH')
    except (KeyError, IndexError):
        return fig

    # --- STEP 1: DYNAMIC DELAY DETECTION ---
    # We calculate the real delay range by comparing STA to CURR_ETA.
    # This ensures if the simulation changes from 7-15 to 30-45, the text updates.
    
    # Check if the dataframe has the ETA column (from sd_plot's internal logic)
    if 'CURR_ETA' in shipments_df.columns:
        shipments_df['actual_delay'] = (pd.to_datetime(shipments_df['CURR_ETA']) - 
                                        pd.to_datetime(shipments_df['STA'])).dt.days
        
        # Filter for shipments that fall within the risk window and were delayed
        mask = (pd.to_datetime(shipments_df['STA']) >= start_date) & \
               (pd.to_datetime(shipments_df['STA']) <= end_date)
        
        impacted_delays = shipments_df[mask & (shipments_df['actual_delay'] > 0)]['actual_delay']
        
        if not impacted_delays.empty:
            low = int(impacted_delays.min())
            high = int(impacted_delays.max())
        else:
            low, high = 7, 15 # Fallback to original observed values
    else:
        low, high = 7, 15

    # --- STEP 2: FIND THE SPIKE (BULLWHIP) DATE ---
    # We scan the plotly figure data to find the highest peak after the window ends.
    spike_date = end_date.strftime('%Y-%m-%d')
    for trace in fig.data:
        # We target the 'Disrupted Supply' line specifically
        if trace.name == "Disrupted Supply" and trace.visible is True:
            df_trace = pd.DataFrame({'date': pd.to_datetime(trace.x), 'qty': trace.y})
            # Filter for dates after the risk window closed
            post_window = df_trace[df_trace['date'] > end_date]
            
            if not post_window.empty:
                # Find the mathematical peak
                max_row = post_window.loc[post_window['qty'].idxmax()]
                spike_date = max_row['date'].strftime('%Y-%m-%d')
            break

    # --- STEP 3: ADD ANNOTATIONS ---
    
    # A. Shade the Risk Window
    fig.add_vrect(
        x0=start_date, x1=end_date,
        fillcolor="red", opacity=0.1,
        layer="below", line_width=1, line_dash="dash", line_color="red",
        row=2, col=1,
        annotation_text=f"RANGA API: {severity} Risk",
        annotation_position="top left",
        annotation_font_color="red"
    )

    # B. Explain the Shortfall
    fig.add_annotation(
        x=start_date.strftime('%Y-%m-%d'), y=0.3,
        xref="x", yref="y2 domain", 
        text=f"<b>Shortfall Onset:</b><br>{low}-{high} day delays applied<br>to orders in this window.",
        showarrow=True, arrowhead=2, arrowsize=1, arrowwidth=2, arrowcolor="#DC2626",
        ax=-70, ay=-40,
        font=dict(color="#F1F5F9", size=11),
        bgcolor="#1E293B", bordercolor="#DC2626"
    )

    # C. Explain the Spike (Convergence)
    fig.add_annotation(
        x=spike_date, y=0.8,
        xref="x", yref="y2 domain",
        text="<b>Inventory Spike:</b><br>Delayed backlog arrives<br>with normal schedule.",
        showarrow=True, arrowhead=2, arrowsize=1, arrowwidth=2, arrowcolor="#059669",
        ax=80, ay=-50,
        font=dict(color="#F1F5F9", size=11),
        bgcolor="#1E293B", bordercolor="#059669"
    )

    return fig
