import json
import re # Make sure this is at the top of your script!

def parse_clinical_jsonl(filepath):
    """Robust parser that fixes single-line concatenated JSON objects."""
    transcript = ""
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            raw_content = f.read().strip()
            
        if not raw_content:
            print(f"  [WARNING] File is completely empty: {filepath}")
            return ""
            
        # THE MAGIC FIX: Find touching brackets like '}{' or '} {' and inject a newline
        fixed_content = re.sub(r'\}\s*\{', '}\n{', raw_content)
        
        # Now we can safely loop through it line-by-line
        for line in fixed_content.split('\n'):
            line = line.strip()
            if not line:
                continue
            
            try:
                data = json.loads(line)
                speaker = data.get("speaker", "Unknown")
                dialogue = data.get("dialogue", "")
                transcript += f"{speaker}: {dialogue}\n"
            except Exception:
                # Fallback if a specific object has a bad typo
                clean_line = line.replace('{"speaker":', 'Speaker:').replace('"dialogue":', '->')
                transcript += f"{clean_line}\n"
                
        return transcript
        
    except Exception as e:
        print(f"  [FATAL ERROR] Could not open file {filepath}: {e}")
        return ""
