import json
import csv
from pathlib import Path
from difflib import SequenceMatcher

# --- 1. CONFIGURATION ---
GT_DIR = Path("data_eval/NER_extracted/Master_English_Ground_Truth")
SUMMARIES_DIR = Path("data_eval/NER_extracted/Experiment_Summaries_GPT")
OUTPUT_CSV = "data_eval/NER_extracted/Programmatic_Evaluation_Results.csv"

# --- 2. MATCHING LOGIC ---
def is_match(term1, term2, threshold=0.8):
    """
    Checks if two terms match either by substring (e.g. 'headache' in 'severe headache')
    or by string similarity (e.g. 'typ2 diabetes' vs 'type 2 diabetes').
    """
    t1, t2 = term1.lower(), term2.lower()
    
    # Direct substring match
    if t1 in t2 or t2 in t1:
        return True
        
    # Fuzzy string similarity
    similarity = SequenceMatcher(None, t1, t2).ratio()
    return similarity >= threshold

def evaluate_lists(gt_list, pred_list):
    """Calculates True Positives, False Positives (Hallucinations), and False Negatives (Omissions)"""
    tp = 0
    matched_preds = set()
    
    for gt_term in gt_list:
        match_found = False
        for i, pred_term in enumerate(pred_list):
            if i not in matched_preds and is_match(gt_term, pred_term):
                tp += 1
                matched_preds.add(i)
                match_found = True
                break
                
    # Hallucinations = Predicted terms that didn't match any GT term
    fp = len(pred_list) - tp 
    
    # Omissions = GT terms that were never matched by a predicted term
    fn = len(gt_list) - tp 
    
    return tp, fp, fn

# --- 3. EXECUTION ---
def run_evaluation():
    results = []
    
    print("Starting Programmatic Evaluation...")
    
    if not GT_DIR.exists() or not SUMMARIES_DIR.exists():
        print("Error: Input directories not found.")
        return
        
    # Iterate through every experiment
    for exp_folder in SUMMARIES_DIR.iterdir():
        if not exp_folder.is_dir(): continue
        experiment_name = exp_folder.name
        
        # Iterate through every language
        for lang_folder in exp_folder.iterdir():
            if not lang_folder.is_dir(): continue
            language = lang_folder.name
            
            # Process every summary JSON
            for summary_file in lang_folder.glob("*_gpt_ner.json"):
                case_id = summary_file.name.replace("_gpt_ner.json", "")
                
                # Find matching Ground Truth
                gt_file = GT_DIR / f"{case_id}_master_ner.json"
                if not gt_file.exists():
                    continue # Skip if no ground truth exists
                    
                with open(summary_file, 'r') as sf, open(gt_file, 'r') as gf:
                    summary_data = json.load(sf).get("Entities", {})
                    gt_data = json.load(gf).get("Ground_Truth_Entities", {})
                    
                total_tp, total_fp, total_fn = 0, 0, 0
                
                # Evaluate each category
                for category in ["Symptoms", "Diagnoses_and_Conditions", "Substances_and_Habits", "Procedures_and_Tests", "Treatments"]:
                    gt_list = gt_data.get(category, [])
                    pred_list = summary_data.get(category, [])
                    
                    tp, fp, fn = evaluate_lists(gt_list, pred_list)
                    total_tp += tp
                    total_fp += fp
                    total_fn += fn
                
                # Calculate Metrics safely
                precision = total_tp / (total_tp + total_fp) if (total_tp + total_fp) > 0 else 0.0
                recall = total_tp / (total_tp + total_fn) if (total_tp + total_fn) > 0 else 0.0
                f1 = (2 * precision * recall) / (precision + recall) if (precision + recall) > 0 else 0.0
                
                results.append({
                    "Case_ID": case_id,
                    "Experiment": experiment_name,
                    "Language": language,
                    "True_Positives (Matches)": total_tp,
                    "False_Positives (Hallucinations)": total_fp,
                    "False_Negatives (Omissions)": total_fn,
                    "Precision": round(precision, 4),
                    "Recall": round(recall, 4),
                    "F1_Score": round(f1, 4)
                })
                
    # Save to CSV
    if results:
        keys = results[0].keys()
        with open(OUTPUT_CSV, 'w', newline='', encoding='utf-8') as f:
            dict_writer = csv.DictWriter(f, keys)
            dict_writer.writeheader()
            dict_writer.writerows(results)
        print(f"Evaluation complete! Results saved to {OUTPUT_CSV}")
    else:
        print("No matches found to evaluate.")

run_evaluation()

