def translate_text(text, src_lang):

    if src_lang == "eng_Latn":
        return text

    inputs = tokenizer(
        text,
        src_lang=src_lang,
        tgt_lang="eng_Latn",
        return_tensors="pt",
        truncation=True,
        max_length=4096
    ).to(DEVICE)

    outputs = model.generate(
        **inputs,
        max_new_tokens=1024,
        num_beams=4
    )

    translated = tokenizer.decode(
        outputs[0],
        skip_special_tokens=True
    )

    return translated
