}

# The folder containing your exact 60 chosen test files per language
REFERENCE_TEST_FOLDER = "data_eval/Final_60_For_Translation/Final_60_For_Translation"

# Dedicated folder for GPT outputs
OUTPUT_ENTITIES_FOLDER = "data_eval/NER_extracted/Experiment_Summaries_GPT"

