# --- 2. CORE FUNCTIONS ---

def read_summary_txt(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            return f.read().strip()
    except Exception as e:
        print(f"  [ERROR] Could not read file {filepath}: {e}")
        return ""

def extract_with_gpt5(summary_text):
    if not summary_text:
        return {}

    system_prompt = """
    You are a clinical data extraction assistant. The following is a generated clinical summary in English. 
    
    Extract structured medical and contextual entities from the summary.

    Follow these strict extraction rules:
    - Format: Extract entities as concise 1-3 word English keywords (e.g., "severe headache", "blood test"), not full sentences.
    - Exact Extraction: Do not hallucinate or add terms that are not present in the text.
    - No Hypotheticals: Do not extract conditions, treatments, or procedures discussed only as possibilities.
    - Separation: Keep discrete concepts separate in the arrays.

    Output your response using ONLY the following JSON schema:
    {
      "Symptoms": [],
      "Diagnoses_and_Conditions": [],
      "Substances_and_Habits": [],
      "Procedures_and_Tests": [],
      "Treatments": []
    }
    """

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": summary_text}
            ],
            response_format={ "type": "json_object" }
        )
        
        raw_content = response.choices[0].message.content
        if not raw_content:
             return {}
        return json.loads(raw_content)
        
    except Exception as e:
        print(f"  [ERROR] GPT API Error: {e}")
        return {}

# --- 3. DIRECTORY TRAVERSAL ---

def process_gpt_experiments(experiments_dict, reference_base_dir, output_base_dir):
    dest_base_path = Path(output_base_dir)
    ref_base_path = Path(reference_base_dir)
    
    print("\n==================================================")
    print("   STARTING FILTERED GPT-5 NER EXTRACTION")
    print("==================================================\n")

    for exp_name, exp_path_str in experiments_dict.items():
        exp_path = Path(exp_path_str)
        if not exp_path.exists():
            continue
            
        print(f"---> Processing Experiment: {exp_name}")
        
        for lang_folder in exp_path.iterdir():
            if not lang_folder.is_dir() or lang_folder.name.startswith('.'):
                continue
                
            language = lang_folder.name
            summary_dir = lang_folder / "Summary_Text"
            
            if not summary_dir.exists():
                continue
                
            # --- THE FILTER LOGIC ---
            # Look up the 60 valid Case IDs for this specific language
            ref_lang_dir = ref_base_path / language / "Dialogues"
            if not ref_lang_dir.exists():
                print(f"     [{language.ljust(10)}] WARNING: No reference folder found. Skipping.")
                continue
                
            valid_cases = {f.name.replace(".jsonl", "") for f in ref_lang_dir.glob("*.jsonl")}
            # ------------------------
            
            dest_lang_dir = dest_base_path / exp_name / language
            dest_lang_dir.mkdir(parents=True, exist_ok=True)
            
            txt_files = list(summary_dir.glob("*_summary.txt"))
            
            # Filter the files to only process ones in our valid list
            filtered_txt_files = [f for f in txt_files if f.name.replace("_summary.txt", "") in valid_cases]
            
            if not filtered_txt_files:
                continue
                
            print(f"     [{language.ljust(10)}] Processing {len(filtered_txt_files)} filtered summaries (out of {len(txt_files)} total)...")
            
            for count, txt_file in enumerate(filtered_txt_files, 1):
                case_id = txt_file.name.replace("_summary.txt", "")
                output_file = dest_lang_dir / f"{case_id}_gpt_ner.json"
                
                # Skip if already processed (Crash recovery)
                if output_file.exists():
                    continue
                
                summary_text = read_summary_txt(txt_file)
                if not summary_text:
                    continue
                    
                gpt_entities = extract_with_gpt5(summary_text)
                
                final_output = {
                    "Case_ID": case_id,
                    "Experiment": exp_name,
                    "Language": language, 
                    "Extractor": "GPT-5",
                    "Entities": gpt_entities
                }
                
                with open(output_file, 'w', encoding='utf-8') as f:
                    json.dump(final_output, f, indent=4)
                    
                if count % 10 == 0:
                    print(f"        ...extracted {count}/{len(filtered_txt_files)}")
                    
            print(f"     [{language.ljust(10)}] ✓ Complete.")

process_gpt_experiments(EXPERIMENTS, REFERENCE_TEST_FOLDER, OUTPUT_ENTITIES_FOLDER)
print("\n--- GPT Extraction Pipeline Finished ---")
