import json
from pathlib import Path

# Path to the extracted JSONs for Mistral Translated
base_json_dir = Path("data_eval/NER_extracted/Experiment_Summaries_GPT/Mistral_Translated")
gt_base_dir = Path("data_eval/NER_extracted/GPT")

print("\n=========================================================")
print("   DIAGNOSING NER JSON FILES & MATCHING LOGIC")
print("=========================================================\n")

langs_to_check = ["Kannada", "Gujarati"]

for lang in langs_to_check:
    lang_dir = base_json_dir / lang
    print(f"--- Checking {lang} ---")
    
    if not lang_dir.exists():
        print(f"  ❌ ERROR: Folder {lang_dir} does not exist!")
        print("     (Did you run the GPT-5 NER Extraction script on the Translated folder?)\n")
        continue
        
    json_files = list(lang_dir.glob("*.json"))
    print(f"  ✅ Found {len(json_files)} JSON files.")
    
    if len(json_files) > 0:
        sample_file = json_files[0]
        print(f"  Sample filename: {sample_file.name}")
        
        # Test the LLM Judge matching logic
        case_id = sample_file.name.replace("_gpt_ner.json", "")
        print(f"  Extracted Case ID: {case_id}")
        
        # Check if GT exists
        gt_lang_dir = gt_base_dir / lang
        gt_file = gt_lang_dir / "Extracted_JSONs" / f"{case_id}_ner.json"
        if not gt_file.exists():
            gt_file = gt_lang_dir / f"{case_id}_ner.json"
            
        if gt_file.exists():
            print("  ✅ Ground Truth MATCH FOUND.")
            
            # Check for gibberish/empty arrays
            with open(sample_file, 'r', encoding='utf-8') as f:
                data = json.load(f).get("Entities", {})
                entity_count = sum(len(v) for v in data.values() if isinstance(v, list))
                print(f"  Entity count in summary: {entity_count}")
                if entity_count == 0:
                    print("  ⚠️ WARNING: The JSON is empty (0 entities). The 'Gibberish' filter will skip this!")
        else:
            print("  ❌ GROUND TRUTH MISMATCH: Cannot find matching GT file.")
            print("     (This is why the Judge is skipping the file!)")
            if "_summary" in case_id:
                print("     💡 FIX: The word '_summary' is stuck in the Case ID!")
    
    print("-" * 50 + "\n")

