from pathlib import Path

# Path to one of your translated folders
translated_dir = Path("data_eval/Mistral_exp/translated/mistral")
ref_dir = Path("data_eval/Final_60_For_Translation/Final 60 For Translation")

print("\n--- DIAGNOSING MISTRAL TRANSLATED FOLDER ---")

if not translated_dir.exists():
    print(f"ERROR: Cannot find folder {translated_dir}")
else:
    for lang_folder in translated_dir.iterdir():
        if not lang_folder.is_dir() or lang_folder.name.startswith('.'): continue
        
        language = lang_folder.name
        summary_dir = lang_folder / "Summary_Text"
        
        if not summary_dir.exists():
            print(f"[{language}] No 'Summary_Text' folder found.")
            continue
            
        txt_files = list(summary_dir.glob("*.txt"))
        
        print(f"\n[{language}] Found {len(txt_files)} summary files.")
        
        if txt_files:
            sample_name = txt_files[0].name
            print(f"    Example filename: {sample_name}")
            
            # Check against the reference list
            ref_lang_dir = ref_dir / language.capitalize() / "Dialogues"
            if ref_lang_dir.exists():
                valid_cases = {f.name.replace(".jsonl", "") for f in ref_lang_dir.glob("*.jsonl")}
                stripped_name = sample_name.replace("_summary.txt", "")
                
                if stripped_name in valid_cases:
                    print("    ✅ Naming format MATCHES the Ground Truth.")
                else:
                    print(f"    ❌ NAMING MISMATCH! '{stripped_name}' is not in the Ground Truth list.")

