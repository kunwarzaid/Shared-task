        valid["norm_ebse"],
        valid["comm_uncertainty_B"]
    )
    print(
        f"Pearson r={pearson_r:.4f}  p={pearson_p:.4f}"
    )
    print(
        f"Spearman r={spearman_r:.4f}  p={spearman_p:.4f}"
    )

    if pearson_r > 0.3:
        print(">> Positive correlation: explanations partially communicate uncertainty")
    elif pearson_r < -0.1:
        print(">> Negative correlation: explanations INVERT uncertainty communication")
    else:
        print(">> Near-zero correlation: explanations do NOT track uncertainty")
else:
    print("Not enough valid rows for correlation.")

