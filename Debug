os.makedirs(OUTPUT_DIR, exist_ok=True)

OUTPUT_CSV = os.path.join(OUTPUT_DIR, "generations.csv")

N_SAMPLES = 10
TEMPERATURE = 0.7
CLUSTER_DISTANCE_THRESHOLD = 0.15
PILOT_SIZE = 100

# =====================================================
# LOGIN
# =====================================================

login(token=HF_TOKEN)
print(f"Model: {MODEL_NAME}")
print(f"Output: {OUTPUT_CSV}")

# =====================================================
# LOAD MODEL
# =====================================================

print("\nLoading tokenizer...")
tokenizer = AutoTokenizer.from_pretrained(
    MODEL_NAME,
    trust_remote_code=True
)

if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

print("Loading model...")
model = AutoModelForCausalLM.from_pretrained(
    MODEL_NAME,
    torch_dtype=torch.float16,
    device_map="auto",
    trust_remote_code=True
)
model.eval()
print("Model loaded.")

if tokenizer.chat_template is not None:
    print("Chat template: FOUND")
else:
    print("Chat template: NOT FOUND — using raw prompt")

# =====================================================
# LOAD SENTENCE ENCODER
# =====================================================

print("Loading sentence encoder...")
encoder = SentenceTransformer(
    'sentence-transformers/all-MiniLM-L6-v2'
)
print("Sentence encoder loaded.")

# =====================================================
# CHAT TEMPLATE HELPER
# =====================================================

def build_prompt(user_message):
    if tokenizer.chat_template is not None:
        messages = [
            {"role": "user", "content": user_message}
        ]
        prompt = tokenizer.apply_chat_template(
            messages,
            tokenize=False,
            add_generation_prompt=True
        )
    else:
        prompt = user_message
    return prompt

# =====================================================
# FUNCTION 1: EBSE
# =====================================================

def compute_ebse(question):

    user_message = (
        f"Answer the following question in one sentence.\n\n"
        f"Question: {question}\n\nAnswer:"
    )
    prompt = build_prompt(user_message)

    inputs = tokenizer(
        prompt,
        return_tensors="pt",
        truncation=True,
        max_length=1024
    ).to(model.device)

    # N_SAMPLES answers with temperature
    with torch.no_grad():
        outputs = model.generate(
            **inputs,
            max_new_tokens=80,
            do_sample=True,
            temperature=TEMPERATURE,
            num_return_sequences=N_SAMPLES,
            pad_token_id=tokenizer.pad_token_id,
            eos_token_id=tokenizer.eos_token_id
        )

    answers = []
    for seq in outputs:
        generated = seq[inputs.input_ids.shape[1]:]
        text = tokenizer.decode(
            generated, skip_special_tokens=True
        ).strip()
        first_line = text.split('\n')[0].strip()
        answers.append(first_line if first_line else text)

    # Greedy answer
    with torch.no_grad():
        greedy_out = model.generate(
            **inputs,
            max_new_tokens=80,
            do_sample=False,
            pad_token_id=tokenizer.pad_token_id,
            eos_token_id=tokenizer.eos_token_id
        )

    greedy_tokens = greedy_out[0][
        inputs.input_ids.shape[1]:
    ]
    greedy_answer = tokenizer.decode(
        greedy_tokens, skip_special_tokens=True
    ).strip()
    greedy_answer = greedy_answer.split('\n')[0].strip()

    # Cluster
    embeddings = encoder.encode(answers)

    if len(answers) > 1:
        clustering = AgglomerativeClustering(
            n_clusters=None,
            distance_threshold=CLUSTER_DISTANCE_THRESHOLD,
            metric='cosine',
            linkage='average'
        )
        labels = clustering.fit_predict(embeddings)
    else:
        labels = np.array([0])

    n_clusters = len(set(labels))
    cluster_dict = {}
    for i, label in enumerate(labels):
        if label not in cluster_dict:
            cluster_dict[label] = []
        cluster_dict[label].append(i)

    clusters = list(cluster_dict.values())
    cluster_probs = np.array(
        [len(c) / N_SAMPLES for c in clusters]
    )

    epsilon = 1e-10
    ebse = -np.sum(
        cluster_probs * np.log(cluster_probs + epsilon)
    )
    max_ebse = np.log(N_SAMPLES)
    norm_ebse = ebse / max_ebse if max_ebse > 0 else 0.0

    cluster_answers = [answers[c[0]] for c in clusters]
    cluster_sizes = [len(c) for c in clusters]

    return (
        greedy_answer,
        answers,
        ebse,
        norm_ebse,
        n_clusters,
        cluster_answers,
        cluster_sizes
    )

# =====================================================
# FUNCTION 2: Explanation Generation
# =====================================================

def get_explanation(question, answer):

    user_message = (
        f"Question: {question}\n\n"
        f"Answer: {answer}\n\n"
        f"Provide an explanation for this answer:"
    )
    prompt = build_prompt(user_message)

    inputs = tokenizer(
        prompt,
        return_tensors="pt",
        truncation=True,
        max_length=1024
    ).to(model.device)

    with torch.no_grad():
        output = model.generate(
            **inputs,
            max_new_tokens=200,
            do_sample=False,
            pad_token_id=tokenizer.pad_token_id,
            eos_token_id=tokenizer.eos_token_id
        )

    generated_tokens = output[0][
        inputs.input_ids.shape[1]:
    ]
    explanation = tokenizer.decode(
        generated_tokens, skip_special_tokens=True
    ).strip()

    return explanation

# =====================================================
# CORRECTNESS CHECK
# =====================================================

STOP_WORDS = {
    'the', 'a', 'an', 'is', 'are', 'was', 'were',
    'of', 'in', 'to', 'and', 'or', 'it', 'its',
    'this', 'that', 'with', 'for', 'on', 'at', 'by'
}

def is_correct(answer, reference_answers):
    answer_words = set(answer.lower().split())
    for ref in reference_answers:
        ref_words = set(ref.lower().split())
        ref_content = ref_words - STOP_WORDS
        if len(ref_content) == 0:
            continue
        overlap = (
            len(answer_words & ref_content)
            / len(ref_content)
        )
        if overlap >= 0.5:
            return 1
    return 0

# =====================================================
# LOAD DATASET
# =====================================================

dataset = load_dataset("truthful_qa", "generation")
questions = list(dataset["validation"])[:PILOT_SIZE]
print(f"\nLoaded {len(questions)} questions.\n")

# =====================================================
# MAIN LOOP
# =====================================================

rows = []

for idx, item in enumerate(questions):

    question = item["question"]
    references = item["correct_answers"]

    print(f"[{idx:03d}/{PILOT_SIZE}] {question[:70]}...")

    try:
        # Step 1: EBSE + sampled answers
        (
            greedy_answer,
            sampled_answers,
            ebse,
            norm_ebse,
            n_clusters,
            cluster_answers,
            cluster_sizes
        ) = compute_ebse(question)

        # Step 2: Explanation
        explanation = get_explanation(
            question, greedy_answer
        )

        # Step 3: Correctness
        correct = is_correct(greedy_answer, references)

        print(
            f"  ebse={norm_ebse:.3f} | "
            f"clusters={n_clusters} | "
            f"expl_len={len(explanation)} | "
            f"correct={correct}"
        )

        rows.append({
            "model": MODEL_SHORT,
            "question": question,
            "greedy_answer": greedy_answer,
            "sampled_answers": " ||| ".join(sampled_answers),
            "cluster_answers": " ||| ".join(cluster_answers),
            "cluster_sizes": str(cluster_sizes),
            "explanation": explanation,
            "correct": correct,
            "references": " | ".join(references),
            "ebse": ebse,
            "norm_ebse": norm_ebse,
            "n_clusters": n_clusters,
        })

    except Exception as e:
        print(f"  ERROR: {e}")
        rows.append({
            "model": MODEL_SHORT,
            "question": question,
            "greedy_answer": None,
            "sampled_answers": None,
            "cluster_answers": None,
            "cluster_sizes": None,
            "explanation": None,
            "correct": None,
            "references": " | ".join(references),
            "ebse": None,
            "norm_ebse": None,
            "n_clusters": None,
        })

    # Incremental save every 10 rows
    if idx % 10 == 0:
        pd.DataFrame(rows).to_csv(
            OUTPUT_CSV, index=False
        )

