```python
import os
import json
import random
from pathlib import Path
from openai import AzureOpenAI

# --- 1. CONFIGURATION ---
# IMPORTANT: Point this to the folder that contains the full dataset JSONLs
# so it can find the Ground Truth for the random files Zero/Few/SFT generated!
RAW_GT_DIR = Path("data_eval/YOUR_FULL_DATASET_FOLDER_HERE") 

MODEL_BASE = "Qwen_exp" # Or Mistral_exp
EXP_PATHS = {
    "Zero-Shot": Path(f"data_eval/{MODEL_BASE}/zeroshot/qwen"),
    "Few-Shot": Path(f"data_eval/{MODEL_BASE}/fewshot/qwen"),
    "SFT": Path(f"data_eval/{MODEL_BASE}/finetune/qwen") 
}

OUTPUT_DIR = Path("data_eval/Deep_Dive_Analysis/Native_Comparisons")

endpoint = "https://ctonpncuaaiopenai.openai.azure.com/"
deployment = "gpt-5"
subscription_key = ""  # Add your Azure key here
api_version = "2024-12-01-preview"

client = AzureOpenAI(
    api_version=api_version,
    azure_endpoint=endpoint,
    api_key=subscription_key,
)

# --- 2. HELPER FUNCTIONS ---
def get_conversation(filepath):
    dialogue_parts = []
    try:
        with open(filepath, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                try:
                    r = json.loads(line.strip())
                    speaker = r.get("speaker", "Unknown")
                    text = r.get("translated_dialogue", r.get("dialogue", ""))
                    if text: dialogue_parts.append(f"{speaker}: {text}")
                except: continue
        return "\n".join(dialogue_parts)
    except: return None

def read_txt(filepath):
    try:
        if filepath.exists():
            with open(filepath, 'r', encoding='utf-8') as f:
                return f.read().strip()
        else:
            return "<MISSING_FILE>"
    except: return "<ERROR_READING>"

def get_case_ids(base_path, lang):
    summary_dir = base_path / lang / "Summary_Text"
    if not summary_dir.exists(): return []
    return [f.name.replace("_summary.txt", "") for f in summary_dir.glob("*_summary.txt")]

def call_gpt_researcher(language, conversation, zero, few, sft):
    system_prompt = """
    You are an objective Clinical NLP Analyst reviewing AI-generated medical summaries.
    You will be provided with a Ground Truth patient-doctor conversation and up to 3 summaries generated by the SAME language model operating natively, using different methodologies: Zero-Shot, Few-Shot, and Supervised Fine-Tuning (SFT).
    (Note: If a methodology says "<MISSING_FILE>", simply ignore it).

    Conduct an unbiased, qualitative evaluation of how these native prompting/training methodologies handled the exact same clinical transcript. 

    Structure your academic report around the following key axes:
    1. Factual Fidelity & Attention: Did any methodology hallucinate facts or omit details? For Few-Shot, explicitly look for "Attention Dilution" (did the model get confused by the long prompt and hallucinate symptoms not present in the Ground Truth?).
    2. Negation Handling: Analyze how each methodology processes negations (e.g., a patient denying a symptom). Did any suffer from "affirmative bias"?
    3. Structural Formatting: Compare organization and clinical tone. Did Few-Shot or SFT successfully force a rigid clinical structure compared to Zero-Shot?
    4. Lexical Nuance: How is native medical terminology handled directly by the LLM? 

    CRITICAL RULE: You MUST write your entire analysis and report strictly in ENGLISH. Provide English translations of the quotes you use to prove your points.
    Output a rich, readable Markdown report. Keep the tone highly academic.
    """
    
    user_prompt = f"""
    LANGUAGE: {language}
    
    === GROUND TRUTH CONVERSATION ===
    {conversation}
    
    === 1. ZERO-SHOT OUTPUT ===
    {zero}
    
    === 2. FEW-SHOT OUTPUT ===
    {few}
    
    === 3. SFT OUTPUT ===
    {sft}
    """

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            temperature=0.1 
        )
        return response.choices[0].message.content
    except Exception as e:
        print(f"API Error: {e}")
        return None

# --- 3. EXECUTION ---
def run_native_deep_dive():
    print("\n--- Starting Native Experiments Qualitative Deep Dive ---")
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    
    if not EXP_PATHS["Zero-Shot"].exists():
        print("ERROR: Could not find the Zero-Shot folder. Please check MODEL_BASE and paths.")
        return
        
    langs = [d.name for d in EXP_PATHS["Zero-Shot"].iterdir() if d.is_dir() and not d.name.startswith('.')]
    
    for language in langs:
        print(f"\nAnalyzing: {language}...")
        
        # Gather Case IDs
        zero_cases = set(get_case_ids(EXP_PATHS["Zero-Shot"], language))
        few_cases = set(get_case_ids(EXP_PATHS["Few-Shot"], language))
        sft_cases = set(get_case_ids(EXP_PATHS["SFT"], language))
        
        # Find the intersection! We want a case that exists in all 3 if possible
        common_cases = zero_cases.intersection(few_cases, sft_cases)
        
        # Fallback if no perfect 3-way match exists: just pick from Zero-Shot
        if common_cases:
            case_id = random.choice(list(common_cases))
            print(f"  Found a perfect match across Zero, Few, and SFT!")
        elif zero_cases:
            case_id = random.choice(list(zero_cases))
            print(f"  No perfect 3-way match. Defaulting to a Zero-Shot case...")
        else:
            print(f"  [SKIPPED] No Zero-Shot text files found for {language}.")
            continue
        
        # Gather the Ground Truth Conversation
        gt_file = RAW_GT_DIR / language / "Dialogues" / f"{case_id}.jsonl"
        if not gt_file.exists(): 
            gt_file = RAW_GT_DIR / language / f"{case_id}.jsonl"
            
        conversation = get_conversation(gt_file)
        if not conversation:
            print(f"  [SKIPPED] Could not find raw JSONL Ground Truth for {case_id}")
            continue
            
        # Read the Summaries
        zero_txt = read_txt(EXP_PATHS["Zero-Shot"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        few_txt = read_txt(EXP_PATHS["Few-Shot"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        sft_txt = read_txt(EXP_PATHS["SFT"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        
        found_count = sum(1 for x in [zero_txt, few_txt, sft_txt] if x != "<MISSING_FILE>")
        print(f"  Found {found_count}/3 experiments for Case ID: {case_id}...")
        
        print(f"  Generating English researcher report...")
        report = call_gpt_researcher(language, conversation, zero_txt, few_txt, sft_txt)
        
        if report:
            out_file = OUTPUT_DIR / f"Native_DeepDive_{language}.md"
            with open(out_file, "w", encoding="utf-8") as f:
                f.write(f"# Native Experiments Analysis: {language} (Case: {case_id})\n\n")
                f.write(report)
            print(f"  ✓ Saved report to {out_file.name}")

run_native_deep_dive()

```
