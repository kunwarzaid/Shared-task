import random
import numpy as np
import pandas as pd
from openai import AzureOpenAI

# =====================================================
# CONFIG
# =====================================================

AZURE_ENDPOINT = "https://rni-openai-azure.openai.azure.com/"
AZURE_API_KEY = ""
AZURE_API_VERSION = "2024-02-01"
DEPLOYMENT_NAME = "gpt-4o"

INPUT_CSV = (
    "/home/coder/test/calibration_explain/"
    "truthfulqa_gpt_judge.csv"
)
PAIRWISE_CSV = (
    "/home/coder/test/calibration_explain/"
    "truthfulqa_gpt_judge_pairwise.csv"
)

MAX_RETRIES = 3

# =====================================================
# CLIENT
# =====================================================

client = AzureOpenAI(
    azure_endpoint=AZURE_ENDPOINT,
    api_key=AZURE_API_KEY,
    api_version=AZURE_API_VERSION
)

# =====================================================
# PAIRWISE JUDGE
# Fix: max_completion_tokens instead of max_tokens
# =====================================================

PAIRWISE_SYSTEM_PROMPT = """You are comparing two
explanations to determine which one communicates
MORE uncertainty to a reader.

Consider hedging language, acknowledgment of
alternatives, and overall confidence of tone.

Do NOT consider factual correctness.

Respond with ONLY one of the following:
A
B"""

PAIRWISE_USER_TEMPLATE = """Explanation A:
{explanation_a}

Explanation B:
{explanation_b}

Which explanation communicates MORE uncertainty?
Respond with only "A" or "B"."""

def pairwise_judge(explanation_a, explanation_b):
    user_message = PAIRWISE_USER_TEMPLATE.format(
        explanation_a=explanation_a,
        explanation_b=explanation_b
    )

    for attempt in range(MAX_RETRIES):
        try:
            response = client.chat.completions.create(
                model=DEPLOYMENT_NAME,
                messages=[
                    {
                        "role": "system",
                        "content": PAIRWISE_SYSTEM_PROMPT
                    },
                    {
                        "role": "user",
                        "content": user_message
                    }
                ],
                temperature=0.0,
                max_completion_tokens=5
            )

            raw = response.choices[0].message.content.strip().upper()

            if "A" in raw and "B" not in raw:
                return "A"
            elif "B" in raw and "A" not in raw:
                return "B"
            else:
                if attempt < MAX_RETRIES - 1:
                    continue
                return None

        except Exception as e:
            print(f"  Error attempt {attempt+1}: {e}")
            if attempt < MAX_RETRIES - 1:
                continue
            return None

    return None

# =====================================================
# LOAD ALREADY SCORED DATA
# =====================================================

df = pd.read_csv(INPUT_CSV)
scored = df[df["gpt_perceived_uncertainty"].notna()].copy()
scored["gpt_perceived_uncertainty"] = scored[
    "gpt_perceived_uncertainty"
].astype(float)

print(f"Loaded {len(scored)} scored examples.")

# =====================================================
# PAIRWISE VALIDATION
# =====================================================

print("\nRunning pairwise validation...")

top10_B = scored.sort_values(
    "comm_uncertainty_B", ascending=False
).head(10).reset_index(drop=True)

bot10_B = scored.sort_values(
    "comm_uncertainty_B", ascending=True
).head(10).reset_index(drop=True)

pairwise_results = []
n_pairs = min(len(top10_B), len(bot10_B))

for i in range(n_pairs):
    high_exp = top10_B.iloc[i]["explanation"]
    low_exp = bot10_B.iloc[i]["explanation"]

    if random.random() < 0.5:
        exp_a = high_exp
        exp_b = low_exp
        correct_answer = "A"
    else:
        exp_a = low_exp
        exp_b = high_exp
        correct_answer = "B"

    result = pairwise_judge(exp_a, exp_b)
    agrees = (
        result == correct_answer
    ) if result is not None else None

    pairwise_results.append({
        "pair_idx": i,
        "high_methodB": top10_B.iloc[i]["comm_uncertainty_B"],
        "low_methodB": bot10_B.iloc[i]["comm_uncertainty_B"],
        "position_of_high": correct_answer,
        "gpt_choice": result,
        "agrees_with_methodB": agrees
    })

    print(
        f"Pair {i:02d}: "
        f"high={top10_B.iloc[i]['comm_uncertainty_B']:.3f} "
        f"low={bot10_B.iloc[i]['comm_uncertainty_B']:.3f} | "
        f"high@{correct_answer} | "
        f"GPT={result} | "
        f"agrees={agrees}"
    )

pairwise_df = pd.DataFrame(pairwise_results)
valid = pairwise_df["agrees_with_methodB"].dropna()
agreement_rate = valid.mean() if len(valid) > 0 else float("nan")

print(f"\nPairwise agreement rate: {agreement_rate:.1%} "
      f"(n={len(valid)})")

if agreement_rate > 0.7:
    print(">> Method B ranking confirmed by GPT pairwise")
elif agreement_rate > 0.5:
    print(">> Weak agreement — Method B partially confirmed")
elif not np.isnan(agreement_rate):
    print(">> Method B ranking NOT confirmed by GPT pairwise")

pairwise_df.to_csv(PAIRWISE_CSV, index=False)
print(f"\nSaved to: {PAIRWISE_CSV}")

# =====================================================
# FINAL FOUR NUMBERS
# =====================================================

from scipy.stats import spearmanr

scored["gpt_perceived_uncert_norm"] = (
    scored["gpt_perceived_uncertainty"] / 100.0
)

r_methodb_gpt, p_methodb_gpt = spearmanr(
    scored["comm_uncertainty_B"],
    scored["gpt_perceived_uncert_norm"]
)
r_ebse_gpt, p_ebse_gpt = spearmanr(
    scored["norm_ebse"],
    scored["gpt_perceived_uncert_norm"]
)

ebse_gap = np.abs(
    scored["norm_ebse"] - scored["gpt_perceived_uncert_norm"]
).mean()

print(f"\n{'='*50}")
print("FINAL FOUR DECISION NUMBERS")
print(f"{'='*50}")
print(f"Method B ↔ GPT Spearman r : {r_methodb_gpt:.4f}  p={p_methodb_gpt:.4f}")
print(f"EBSE     ↔ GPT Spearman r : {r_ebse_gpt:.4f}  p={p_ebse_gpt:.4f}")
print(f"Pairwise agreement rate   : {agreement_rate:.1%}")
print(f"Mean EBSE-GPT mismatch    : {ebse_gap:.4f}")
