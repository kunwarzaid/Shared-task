    print(f"[Method B] comm_certainty={comm_certainty_B:.4f} | avg_cert_mass={avg_certainty_B:.6f} | avg_uncert_mass={avg_uncertainty_B:.6f}")

    # UCG using Method B (more reliable)
    ucg_B = normalized_entropy - comm_uncertainty_B

    print(f"UCG (Method B): {ucg_B:.4f}")

    rows.append({
        "idx": idx,
        "question": question,
        "answer": answer,
        "explanation": explanation,
        "top1_token": top1_token_str,

        # Internal uncertainty
        "entropy_nats": entropy_nats,
        "normalized_entropy": normalized_entropy,
        "top1_prob": top1_prob,
        "margin": margin,

        # Communicated uncertainty Method A
        "comm_certainty_A": comm_certainty_A,
