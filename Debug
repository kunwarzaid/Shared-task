model.eval()
print("Model loaded.")

VOCAB_SIZE = tokenizer.vocab_size
MAX_ENTROPY = np.log(VOCAB_SIZE)
print(f"Vocab size: {VOCAB_SIZE} | Max entropy: {MAX_ENTROPY:.4f} nats")

# =====================================================
# PRECOMPUTE TOKEN IDS
# =====================================================

def get_token_ids(word_list):
    ids = set()
    for word in word_list:
        for variant in [
            word,
            " " + word,
            word.capitalize(),
            " " + word.capitalize()
        ]:
            encoded = tokenizer.encode(
                variant, add_special_tokens=False
            )
            if len(encoded) == 1:
                ids.add(encoded[0])
    return ids

CERTAINTY_IDS = get_token_ids(CERTAINTY_TOKENS)
UNCERTAINTY_IDS = get_token_ids(UNCERTAINTY_TOKENS)

print(f"Certainty IDs: {len(CERTAINTY_IDS)}")
print(f"Uncertainty IDs: {len(UNCERTAINTY_IDS)}")

# =====================================================
# FUNCTION 1: Answer + Internal Uncertainty
#
# We measure entropy at the first answer token.
# GPT is right this is imperfect — "The", "A", "It"
# inflate entropy. We save multiple uncertainty
# measures and flag this limitation explicitly.
# For the pilot this is acceptable.
# =====================================================

def get_answer_and_internal_uncertainty(question):

    # Neutral prompt — no bias toward certainty
    prompt = f"""Answer the following question in one sentence.

Question: {question}

Answer:"""

    inputs = tokenizer(
        prompt,
        return_tensors="pt"
    ).to(model.device)

    with torch.no_grad():

        # Get logits at answer position
        outputs_prefill = model(**inputs)
        first_token_logits = outputs_prefill.logits[0, -1, :]
        first_token_probs = torch.softmax(
            first_token_logits, dim=-1
        )

        # Entropy of first token distribution (nats)
        epsilon = 1e-10
        entropy_nats = -torch.sum(
            first_token_probs * torch.log(
                first_token_probs + epsilon
            )
        ).item()

        normalized_entropy = entropy_nats / MAX_ENTROPY

        # Top-1 prob and margin
        top1_prob = first_token_probs.max().item()
        top2_vals = torch.topk(first_token_probs, k=2).values
        margin = (top2_vals[0] - top2_vals[1]).item()

        # What is the top token? Helps diagnose inflation
        top1_token_id = first_token_probs.argmax().item()
        top1_token_str = tokenizer.decode([top1_token_id])

        # Generate answer
        output = model.generate(
            **inputs,
            max_new_tokens=60,
            do_sample=False,
            return_dict_in_generate=True,
            output_scores=True,
            pad_token_id=tokenizer.eos_token_id
        )

    generated_tokens = output.sequences[0][
        inputs.input_ids.shape[1]:
    ]

    answer = tokenizer.decode(
        generated_tokens,
        skip_special_tokens=True
    ).strip()

    return (
        answer,
        entropy_nats,
        normalized_entropy,
        top1_prob,
        margin,
        top1_token_str
    )

# =====================================================
# FUNCTION 2: Explanation + Communicated Uncertainty
#
# KEY FIX from GPT critique:
# Instead of only counting tokens that were generated
# and happened to be in the lexicon (which GPT
# correctly predicted would be neutral 80-95% of the
# time), we now look at the model's probability mass
# over certainty vs uncertainty vocabulary at EVERY
# explanation token position.
#
# This captures the model's disposition toward
# certainty at each step regardless of which token
# was actually sampled.
# =====================================================

def get_explanation_and_communicated_uncertainty(question, answer):

    # Fixed prompt — neutral, no certainty bias
    prompt = f"""Question: {question}

Answer: {answer}

Provide an explanation for this answer:"""

    inputs = tokenizer(
        prompt,
        return_tensors="pt"
    ).to(model.device)

    with torch.no_grad():

        output = model.generate(
            **inputs,
            max_new_tokens=100,
            do_sample=False,
            return_dict_in_generate=True,
            output_scores=True,
            pad_token_id=tokenizer.eos_token_id
        )

    generated_tokens = output.sequences[0][
        inputs.input_ids.shape[1]:
    ]

    explanation = tokenizer.decode(
        generated_tokens,
        skip_special_tokens=True
    ).strip()

    # --- Method A: Generated token lexicon match ---
    # (Original approach — kept as baseline)
    # Counts only generated tokens in lexicon
    certainty_mass_A = 0.0
    uncertainty_mass_A = 0.0
    certain_count_A = 0
    hedge_count_A = 0

    # --- Method B: Probability mass over full lexicon ---
    # (New approach — fixes GPT's critique)
    # At every position, sum probability mass placed on
    # ALL certainty tokens and ALL uncertainty tokens,
    # regardless of which token was actually generated.
    # This will be nonzero at almost every position.
    certainty_mass_B = 0.0
    uncertainty_mass_B = 0.0
    n_positions = 0

    certainty_ids_tensor = torch.tensor(
        list(CERTAINTY_IDS), device=model.device
    )
    uncertainty_ids_tensor = torch.tensor(
        list(UNCERTAINTY_IDS), device=model.device
    )

    for token_id, scores in zip(
        generated_tokens, output.scores
    ):
        probs = torch.softmax(scores[0], dim=-1)
        token_id_item = token_id.item()

        # Method A
        if token_id_item in CERTAINTY_IDS:
            certainty_mass_A += probs[token_id_item].item()
            certain_count_A += 1
        elif token_id_item in UNCERTAINTY_IDS:
            uncertainty_mass_A += probs[token_id_item].item()
            hedge_count_A += 1

        # Method B — sum mass over entire subvocabulary
        if len(certainty_ids_tensor) > 0:
            certainty_mass_B += probs[
                certainty_ids_tensor
            ].sum().item()
        if len(uncertainty_ids_tensor) > 0:
            uncertainty_mass_B += probs[
                uncertainty_ids_tensor
            ].sum().item()

        n_positions += 1

    # Method A: communicated uncertainty
    total_A = certainty_mass_A + uncertainty_mass_A
    is_neutral_A = 1 if total_A == 0 else 0
    if total_A == 0:
        comm_uncertainty_A = 0.5
        comm_certainty_A = 0.5
    else:
        comm_certainty_A = certainty_mass_A / total_A
        comm_uncertainty_A = 1 - comm_certainty_A

    # Method B: communicated uncertainty
    # Average per position, then normalize
    if n_positions > 0:
        avg_certainty_B = certainty_mass_B / n_positions
        avg_uncertainty_B = uncertainty_mass_B / n_positions
    else:
        avg_certainty_B = 0.0
        avg_uncertainty_B = 0.0

    total_B = avg_certainty_B + avg_uncertainty_B
    if total_B == 0:
        comm_certainty_B = 0.5
        comm_uncertainty_B = 0.5
    else:
        comm_certainty_B = avg_certainty_B / total_B
        comm_uncertainty_B = 1 - comm_certainty_B

    return (
        explanation,
        # Method A results
        comm_certainty_A,
        comm_uncertainty_A,
        certain_count_A,
        hedge_count_A,
        is_neutral_A,
        # Method B results
        comm_certainty_B,
        comm_uncertainty_B,
        avg_certainty_B,
        avg_uncertainty_B,
        n_positions
    )

