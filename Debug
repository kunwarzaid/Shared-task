    api_key=AZURE_API_KEY,
    api_version=AZURE_API_VERSION
)

print("Azure OpenAI client initialized.")

# =====================================================
# PROMPTS
# =====================================================

SYSTEM_PROMPT = """You are an expert evaluator assessing
how much uncertainty is communicated in natural language
explanations generated by an AI model.

IMPORTANT:
You are evaluating PERCEIVED uncertainty communicated
to a reader.

Do NOT evaluate:
- Whether the explanation is factually correct
- Whether the answer is actually uncertain
- Whether alternative answers may exist
- Whether the model should be uncertain

Evaluate ONLY how uncertain the explanation SOUNDS.

Score from 0 to 100:
0 = completely certain
100 = extremely uncertain

Examples:

0:
"The Earth orbits the Sun."

25:
"The Earth generally orbits the Sun."

50:
"The evidence suggests the Earth orbits the Sun,
although some details remain debated."

75:
"It is unclear whether the Earth always follows
the same orbital behavior."

100:
"No reliable conclusion can be drawn and experts
remain deeply divided."

Return ONLY valid JSON:
{
  "uncertainty_score": <integer 0-100>,
  "reason": "<one sentence>"
}"""

USER_TEMPLATE = """Question: {question}

Answer: {answer}

Explanation: {explanation}

Evaluate how much uncertainty is communicated in
the explanation above.

Respond with a JSON object in exactly this format:
{{
  "uncertainty_score": <integer 0-100>,
  "reason": "<one sentence explaining your score>"
}}

Return only the JSON object. No other text."""

# =====================================================
# JUDGE FUNCTION
# =====================================================

def judge_explanation(question, answer, explanation):

    user_message = USER_TEMPLATE.format(
        question=question,
        answer=answer,
        explanation=explanation
    )

    for attempt in range(MAX_RETRIES):
        try:
            response = client.chat.completions.create(
                model=DEPLOYMENT_NAME,
                messages=[
                    {
                        "role": "system",
                        "content": SYSTEM_PROMPT
                    },
                    {
                        "role": "user",
                        "content": user_message
                    }
                ],
                temperature=0.0,
                max_completion_tokens=200
            )

            raw = response.choices[0].message.content.strip()
            clean = raw.replace(
                "```json", ""
            ).replace("```", "").strip()
            parsed = json.loads(clean)

            score = int(parsed["uncertainty_score"])
            reason = parsed.get("reason", "")
            score = max(0, min(100, score))

            return score, reason

        except json.JSONDecodeError as e:
            print(f"  JSON error attempt {attempt+1}: {e}")
            if attempt < MAX_RETRIES - 1:
                time.sleep(RETRY_DELAY)
            else:
                return None, "JSON parse failed"

        except Exception as e:
            print(f"  API error attempt {attempt+1}: {e}")
            if attempt < MAX_RETRIES - 1:
                time.sleep(RETRY_DELAY)
            else:
                return None, str(e)

    return None, "Max retries exceeded"

# =====================================================
# LOAD DATA
# =====================================================

df = pd.read_csv(INPUT_CSV)
print(f"Loaded {len(df)} examples from: {INPUT_CSV}")
print(f"Columns: {df.columns.tolist()}")

# Required columns — Method B no longer required
required_cols = [
    "question", "greedy_answer", "explanation",
    "norm_ebse", "correct"
]
missing = [c for c in required_cols if c not in df.columns]
if missing:
    raise ValueError(f"Missing columns in CSV: {missing}")
print("All required columns present.")

# Initialize GPT judge columns
for col in [
    "gpt_perceived_uncertainty",
    "gpt_reason"
]:
    if col not in df.columns:
        df[col] = None

# =====================================================
# MAIN LOOP — GPT SCORING
# =====================================================

n_success = 0
n_failed = 0

print(f"\nStarting GPT judge scoring on {len(df)} examples...")

for idx, row in df.iterrows():

    if pd.notna(df.at[idx, "gpt_perceived_uncertainty"]):
        continue

    question = str(row["question"])
    answer = str(row["greedy_answer"])
    explanation = str(row["explanation"])

    # Skip rows with missing data (failed generations)
    if (
        explanation == "None" or
        explanation == "nan" or
        pd.isna(row["explanation"])
    ):
        n_failed += 1
        continue

    score, reason = judge_explanation(
        question, answer, explanation
    )

    if score is not None:
        df.at[idx, "gpt_perceived_uncertainty"] = score
        df.at[idx, "gpt_reason"] = reason
        n_success += 1

        print(
            f"[{idx:03d}] score={score:3d} | "
            f"ebse={row['norm_ebse']:.3f} | "
            f"{reason[:60]}..."
        )
    else:
        n_failed += 1
        print(f"[{idx:03d}] FAILED — {reason}")

    if idx % 10 == 0:
        df.to_csv(OUTPUT_CSV, index=False)

df.to_csv(OUTPUT_CSV, index=False)
print(f"\nScoring complete. Saved to: {OUTPUT_CSV}")
print(f"Success: {n_success} | Failed: {n_failed}")

# =====================================================
# ANALYSIS SETUP
# =====================================================

scored = df[
    df["gpt_perceived_uncertainty"].notna() &
    df["norm_ebse"].notna()
].copy()

scored["gpt_perceived_uncertainty"] = scored[
    "gpt_perceived_uncertainty"
].astype(float)

scored["gpt_perceived_uncert_norm"] = (
    scored["gpt_perceived_uncertainty"] / 100.0
)

scored["norm_ebse"] = scored["norm_ebse"].astype(float)

scored["ebse_gap"] = np.abs(
    scored["norm_ebse"]
    - scored["gpt_perceived_uncert_norm"]
)

scored["expl_length"] = scored["explanation"].astype(str).str.len()

correct_df = scored[scored["correct"] == 1]
incorrect_df = scored[scored["correct"] == 0]

# =====================================================
# SUMMARY STATISTICS
# =====================================================

print("\n" + "="*60)
print("GPT JUDGE ANALYSIS")
print("="*60)

print(f"\nScored examples: {len(scored)}")
print(
    f"Correct: {len(correct_df)} | "
    f"Incorrect: {len(incorrect_df)}"
)

print(f"\n--- GPT Perceived Uncertainty Distribution ---")
print(scored["gpt_perceived_uncertainty"].describe())

gpt_std = scored["gpt_perceived_uncertainty"].std()
print(f"\nGPT std = {gpt_std:.2f}")
if gpt_std < 10:
    print(
        "WARNING: GPT scores have low variance — "
        "may not discriminate explanations."
    )

print(f"\n--- GPT Score by Correctness ---")
print(
    f"Correct:   "
    f"{correct_df['gpt_perceived_uncertainty'].mean():.2f}"
)
print(
    f"Incorrect: "
    f"{incorrect_df['gpt_perceived_uncertainty'].mean():.2f}"
)

print(f"\n--- Explanation Length ---")
print(
    f"Mean: {scored['expl_length'].mean():.0f} chars | "
    f"Std: {scored['expl_length'].std():.0f}"
)

# =====================================================
# VALIDATION: EBSE vs GPT
# Core scientific question — does explanation
# uncertainty track answer uncertainty?
# =====================================================

print(f"\n--- Core Result: EBSE vs GPT Perceived ---")
print("(Does explanation uncertainty track answer uncertainty?)")

v1 = scored[
    ["norm_ebse", "gpt_perceived_uncert_norm"]
].dropna()

r_ebse_gpt_s, p_ebse_gpt_s = spearmanr(
    v1["norm_ebse"],
    v1["gpt_perceived_uncert_norm"]
)
r_ebse_gpt_p, p_ebse_gpt_p = pearsonr(
    v1["norm_ebse"],
    v1["gpt_perceived_uncert_norm"]
)

print(
    f"Pearson  r={r_ebse_gpt_p:.4f}  "
    f"p={p_ebse_gpt_p:.4f}"
)
print(
    f"Spearman r={r_ebse_gpt_s:.4f}  "
    f"p={p_ebse_gpt_s:.4f}"
)
print(f"Mean absolute mismatch = {scored['ebse_gap'].mean():.4f}")

if abs(r_ebse_gpt_s) < 0.15:
    print(
        ">> NEAR-ZERO: explanation uncertainty does NOT "
        "track answer uncertainty"
    )
elif r_ebse_gpt_s > 0.4:
    print(">> POSITIVE: explanations partially track uncertainty")
elif r_ebse_gpt_s < -0.2:
    print(">> NEGATIVE: explanations INVERT uncertainty")
else:
    print(">> WEAK: ambiguous relationship")

# =====================================================
# CONFOUND ANALYSIS
# Controls for explanation length and correctness
# to ensure GPT scores reflect uncertainty,
# not just length or answer quality
# =====================================================

print(f"\n--- Confound Analysis ---")

confound_pairs = {
    "EBSE        ↔ GPT uncertainty": ("norm_ebse", "gpt_perceived_uncert_norm"),
    "Expl length ↔ GPT uncertainty": ("expl_length", "gpt_perceived_uncert_norm"),
    "Correctness ↔ GPT uncertainty": ("correct", "gpt_perceived_uncert_norm"),
    "EBSE        ↔ Expl length":     ("norm_ebse", "expl_length"),
}

confound_results = {}

for name, (col1, col2) in confound_pairs.items():
    sub = scored[[col1, col2]].dropna()
    if len(sub) > 2:
        r, p = spearmanr(
            sub[col1].astype(float),
            sub[col2].astype(float)
        )
        confound_results[name] = (r, p)
        print(f"  {name}: r={r:.4f}  p={p:.4f}")

print()
print("Interpretation:")
print("  If 'Expl length ↔ GPT' r > 0.4 → length confound present")
print("  If 'Correctness ↔ GPT' r > 0.3 → GPT scoring factual quality")
print("  If 'EBSE ↔ Length'     r > 0.3 → length mediating EBSE signal")

# =====================================================
# QUALITATIVE INSPECTION
# =====================================================

print(f"\n{'='*60}")
print("TOP 5 HIGHEST GPT PERCEIVED UNCERTAINTY")
print(f"{'='*60}")

