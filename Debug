print(f"\n--- Correlation: EBSE vs Comm Uncertainty B ---")
print("(Does explanation uncertainty track answer uncertainty?)")

valid = df[
    ["norm_ebse", "comm_uncertainty_B"]
].dropna()

if len(valid) > 2:
    pearson_r, pearson_p = pearsonr(
        valid["norm_ebse"],
