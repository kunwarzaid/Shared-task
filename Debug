```python
import os
import json
import random
from pathlib import Path
from openai import AzureOpenAI

# --- 1. CONFIGURATION ---
RAW_GT_DIR = Path("data_eval/YOUR_NEW_TEST_FOLDER_NAME_HERE") 

MODEL_BASE = "Qwen_exp" # Or Mistral_exp
EXP_PATHS = {
    "Zero-Shot": Path(f"data_eval/{MODEL_BASE}/zeroshot/qwen"),
    "Few-Shot": Path(f"data_eval/{MODEL_BASE}/fewshot/qwen"),
    "Translated": Path(f"data_eval/{MODEL_BASE}/translated/qwen"),
    "SFT": Path(f"data_eval/{MODEL_BASE}/finetune/qwen") 
}

OUTPUT_DIR = Path("data_eval/Deep_Dive_Analysis")

endpoint = "https://ctonpncuaaiopenai.openai.azure.com/"
deployment = "gpt-5"
subscription_key = ""  # Add your Azure key here
api_version = "2024-12-01-preview"

client = AzureOpenAI(
    api_version=api_version,
    azure_endpoint=endpoint,
    api_key=subscription_key,
)

# --- 2. HELPER FUNCTIONS ---
def get_conversation(filepath):
    dialogue_parts = []
    try:
        with open(filepath, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                try:
                    r = json.loads(line.strip())
                    speaker = r.get("speaker", "Unknown")
                    text = r.get("translated_dialogue", r.get("dialogue", ""))
                    if text: dialogue_parts.append(f"{speaker}: {text}")
                except: continue
        return "\n".join(dialogue_parts)
    except: return None

def read_txt(filepath):
    try:
        if filepath.exists():
            with open(filepath, 'r', encoding='utf-8') as f:
                return f.read().strip()
        else:
            return "<MISSING_FILE>"
    except: return "<ERROR_READING>"

def get_case_ids(base_path, lang):
    summary_dir = base_path / lang / "Summary_Text"
    if not summary_dir.exists(): return []
    return [f.name.replace("_summary.txt", "") for f in summary_dir.glob("*_summary.txt")]

def call_gpt_researcher(language, conversation, zero, few, trans, sft):
    system_prompt = """
    You are an objective Clinical NLP Analyst reviewing AI-generated medical summaries.
    You will be provided with a Ground Truth patient-doctor conversation and up to 4 summaries generated by different prompting methodologies.
    (Note: If a methodology says "<MISSING_FILE>", simply ignore it in your comparison).

    Conduct an unbiased, qualitative evaluation of how the available methodologies handled the exact same clinical transcript. 

    Structure your academic report around the following key axes:
    1. Factual Fidelity: Identify if any methodology hallucinated facts or omitted critical clinical details present in the ground truth.
    2. Negation Handling (CRITICAL): Analyze how each methodology processes negations (e.g., a patient denying a symptom). Did any suffer from "affirmative bias"?
    3. Structural Formatting: Compare organization and clinical tone. 
    4. Lexical Choice & Nuance: How is specific medical terminology handled? Are nuanced sentiments preserved?

    CRITICAL RULE: You MUST write your entire analysis and report strictly in ENGLISH, even if the provided conversation is in another language. Provide English translations of the quotes you use.
    Output a rich, readable Markdown report. Cite specific, short quotes from the provided texts to justify your comparisons. Keep the tone highly academic.
    """
    
    user_prompt = f"""
    LANGUAGE: {language}
    
    === GROUND TRUTH CONVERSATION ===
    {conversation}
    
    === 1. ZERO-SHOT OUTPUT ===
    {zero}
    
    === 2. FEW-SHOT OUTPUT ===
    {few}
    
    === 3. TRANSLATED OUTPUT ===
    {trans}
    
    === 4. SFT OUTPUT ===
    {sft}
    """

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            temperature=0.1 
        )
        return response.choices[0].message.content
    except Exception as e:
        print(f"API Error: {e}")
        return None

# --- 3. EXECUTION ---
def run_deep_dive():
    print("\n--- Starting Fault-Tolerant Qualitative Deep Dive ---")
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    
    if not EXP_PATHS["Translated"].exists():
        print("ERROR: Could not find the Translated folder. Please check MODEL_BASE and paths.")
        return
        
    langs = [d.name for d in EXP_PATHS["Translated"].iterdir() if d.is_dir() and not d.name.startswith('.')]
    
    for language in langs:
        print(f"\nAnalyzing: {language}...")
        
        trans_cases = get_case_ids(EXP_PATHS["Translated"], language)
        
        if not trans_cases:
            print(f"  [SKIPPED] No translated text files found for {language}.")
            continue
            
        case_id = random.choice(trans_cases)
        
        gt_file = RAW_GT_DIR / language / "Dialogues" / f"{case_id}.jsonl"
        if not gt_file.exists(): 
            gt_file = RAW_GT_DIR / language / f"{case_id}.jsonl"
            
        conversation = get_conversation(gt_file)
        if not conversation:
            print(f"  [SKIPPED] Could not find raw JSONL for {case_id}")
            continue
            
        zero_txt = read_txt(EXP_PATHS["Zero-Shot"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        few_txt = read_txt(EXP_PATHS["Few-Shot"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        trans_txt = read_txt(EXP_PATHS["Translated"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        sft_txt = read_txt(EXP_PATHS["SFT"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        
        # Fixed the bug here! Checks for the exact missing tag instead of the bracket [
        found_count = sum(1 for x in [zero_txt, few_txt, trans_txt, sft_txt] if x != "<MISSING_FILE>")
        print(f"  Found {found_count}/4 experiments for Case ID: {case_id}...")
        
        print(f"  Generating English researcher report...")
        report = call_gpt_researcher(language, conversation, zero_txt, few_txt, trans_txt, sft_txt)
        
        if report:
            out_file = OUTPUT_DIR / f"Objective_DeepDive_{language}.md"
            with open(out_file, "w", encoding="utf-8") as f:
                f.write(f"# Objective Deep Dive Analysis: {language} (Case: {case_id})\n\n")
                f.write(report)
            print(f"  ✓ Saved report to {out_file.name}")

run_deep_dive()


```
