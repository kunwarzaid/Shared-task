```python
import os
import json
import random
from pathlib import Path
from openai import AzureOpenAI

# --- 1. CONFIGURATION ---
RAW_GT_DIR = Path("data_eval/YOUR_NEW_TEST_FOLDER_NAME_HERE") 

MODEL_BASE = "Qwen_exp" # Or Mistral_exp
EXP_PATHS = {
    "Zero-Shot": Path(f"data_eval/{MODEL_BASE}/zeroshot/qwen"),
    "Few-Shot": Path(f"data_eval/{MODEL_BASE}/fewshot/qwen"),
    "Translated": Path(f"data_eval/{MODEL_BASE}/translated/qwen"),
    "SFT": Path(f"data_eval/{MODEL_BASE}/finetune/qwen") 
}

OUTPUT_DIR = Path("data_eval/Deep_Dive_Analysis")

endpoint = "https://ctonpncuaaiopenai.openai.azure.com/"
deployment = "gpt-5"
subscription_key = ""  # Add your Azure key here
api_version = "2024-12-01-preview"

client = AzureOpenAI(
    api_version=api_version,
    azure_endpoint=endpoint,
    api_key=subscription_key,
)

# --- 2. HELPER FUNCTIONS ---
def get_conversation(filepath):
    dialogue_parts = []
    try:
        with open(filepath, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                try:
                    r = json.loads(line.strip())
                    speaker = r.get("speaker", "Unknown")
                    text = r.get("translated_dialogue", r.get("dialogue", ""))
                    if text: dialogue_parts.append(f"{speaker}: {text}")
                except: continue
        return "\n".join(dialogue_parts)
    except: return None

def read_txt(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            return f.read().strip()
    except: return "[FILE NOT FOUND OR EMPTY]"

def get_case_ids(base_path, lang):
    summary_dir = base_path / lang / "Summary_Text"
    if not summary_dir.exists(): return set()
    return {f.name.replace("_summary.txt", "") for f in summary_dir.glob("*_summary.txt")}

def call_gpt_researcher(language, conversation, zero, few, trans, sft):
    system_prompt = """
    You are an objective Clinical NLP Analyst reviewing AI-generated medical summaries.
    You will be provided with:
    1. A raw Ground Truth patient-doctor conversation.
    2. Four summaries generated by the SAME language model, but using four different methodologies (Zero-Shot, Few-Shot, Translated, SFT).

    Your task is to conduct an unbiased, qualitative evaluation of how the four methodologies handled the exact same clinical transcript. 
    Do NOT assume any method is inherently better or worse. Base your entire analysis strictly on the provided texts.

    Structure your academic report around the following key axes:
    1. Factual Fidelity: Objectively identify if any methodology hallucinated facts (invented symptoms/medications) or omitted critical clinical details present in the ground truth.
    2. Negation Handling (CRITICAL): Carefully analyze how each methodology processes negations from the transcript (e.g., when a patient denies a symptom or a doctor rules out a condition). Did any method suffer from "affirmative bias" by recording a denied symptom as present? Did translation alter the scope of the negation?
    3. Structural Formatting: Compare how the organization and clinical tone differ across the methods. Which produce standard clinical notes vs. conversational recaps?
    4. Lexical Choice & Nuance: How is specific medical terminology handled? Are nuanced patient sentiments preserved, or abstracted into generic terms?

    Output a rich, readable Markdown report. You MUST cite specific, short quotes from the provided texts to justify your comparisons. Keep the tone highly academic and strictly data-driven.
    """
    
    user_prompt = f"""
    LANGUAGE: {language}
    
    === GROUND TRUTH CONVERSATION ===
    {conversation}
    
    === 1. ZERO-SHOT OUTPUT ===
    {zero}
    
    === 2. FEW-SHOT OUTPUT ===
    {few}
    
    === 3. TRANSLATED OUTPUT ===
    {trans}
    
    === 4. SFT OUTPUT ===
    {sft}
    """

    try:
        response = client.chat.completions.create(
            model=deployment, 
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            temperature=0.1 # Very low temperature for maximum analytical objectivity
        )
        return response.choices[0].message.content
    except Exception as e:
        print(f"API Error: {e}")
        return None

# --- 3. EXECUTION ---
def run_deep_dive():
    print("\n--- Starting Unbiased Qualitative Deep Dive ---")
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    
    langs = [d.name for d in EXP_PATHS["Zero-Shot"].iterdir() if d.is_dir() and not d.name.startswith('.')]
    
    for language in langs:
        print(f"\nAnalyzing: {language}...")
        
        zero_cases = get_case_ids(EXP_PATHS["Zero-Shot"], language)
        few_cases = get_case_ids(EXP_PATHS["Few-Shot"], language)
        trans_cases = get_case_ids(EXP_PATHS["Translated"], language)
        sft_cases = get_case_ids(EXP_PATHS["SFT"], language)
        
        common_cases = zero_cases.intersection(few_cases, trans_cases, sft_cases)
        
        if not common_cases:
            print(f"  [SKIPPED] No common Case IDs found across all 4 experiments for {language}.")
            continue
            
        print(f"  Found {len(common_cases)} cases common across all 4 pipelines.")
        case_id = random.choice(list(common_cases))
        
        gt_file = RAW_GT_DIR / language / "Dialogues" / f"{case_id}.jsonl"
        if not gt_file.exists(): gt_file = RAW_GT_DIR / language / f"{case_id}.jsonl"
            
        conversation = get_conversation(gt_file)
        if not conversation:
            print(f"  [SKIPPED] Could not find raw JSONL for {case_id}")
            continue
            
        zero_txt = read_txt(EXP_PATHS["Zero-Shot"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        few_txt = read_txt(EXP_PATHS["Few-Shot"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        trans_txt = read_txt(EXP_PATHS["Translated"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        sft_txt = read_txt(EXP_PATHS["SFT"] / language / "Summary_Text" / f"{case_id}_summary.txt")
        
        print(f"  Generating objective researcher report for Case ID: {case_id}...")
        report = call_gpt_researcher(language, conversation, zero_txt, few_txt, trans_txt, sft_txt)
        
        if report:
            out_file = OUTPUT_DIR / f"Objective_DeepDive_{language}.md"
            with open(out_file, "w", encoding="utf-8") as f:
                f.write(f"# Objective Deep Dive Analysis: {language} (Case: {case_id})\n\n")
                f.write(report)
            print(f"  ✓ Saved report to {out_file.name}")

run_deep_dive()


```
