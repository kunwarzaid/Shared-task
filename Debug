import torch
import pandas as pd
from tqdm import tqdm
from transformers import AutoTokenizer, AutoModelForCausalLM

MODEL_NAME = "meta-llama/Llama-3.1-8B-Instruct"

tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)

model = AutoModelForCausalLM.from_pretrained(
    MODEL_NAME,
    torch_dtype=torch.float16,
    device_map="auto"
)

model.eval()


def generate_answer_and_confidence(question):

    prompt = f"""Question:
{question}

Answer with only the final answer.
"""

    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)

    with torch.no_grad():

        output = model.generate(
            **inputs,
            max_new_tokens=20,
            do_sample=False,
            return_dict_in_generate=True,
            output_scores=True
        )

    generated_tokens = output.sequences[0][inputs.input_ids.shape[1]:]

    answer = tokenizer.decode(
        generated_tokens,
        skip_special_tokens=True
    ).strip()

    token_probs = []

    for token_id, scores in zip(
        generated_tokens,
        output.scores
    ):

        probs = torch.softmax(scores[0], dim=-1)

        prob = probs[token_id].item()

        token_probs.append(prob)

    avg_confidence = (
        sum(token_probs) / len(token_probs)
        if len(token_probs) > 0 else 0
    )

    uncertainty = 1 - avg_confidence

    return answer, avg_confidence, uncertainty


def generate_explanation(question, answer):

    prompt = f"""Question:
{question}

Answer:
{answer}

Explain why this answer is correct.
"""

    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)

    with torch.no_grad():

        output = model.generate(
            **inputs,
            max_new_tokens=256,
            do_sample=False
        )

    explanation = tokenizer.decode(
        output[0][inputs.input_ids.shape[1]:],
        skip_special_tokens=True
    )

    return explanation.strip()


# Example questions
questions = [
    "What is the capital of France?",
    "Can coughing stop a heart attack?"
]

rows = []

for q in tqdm(questions):

    answer, confidence, uncertainty = \
        generate_answer_and_confidence(q)

    explanation = generate_explanation(
        q,
        answer
    )

    rows.append({
        "question": q,
        "answer": answer,
        "avg_confidence": confidence,
        "uncertainty": uncertainty,
        "explanation": explanation
    })

df = pd.DataFrame(rows)

df.to_csv(
    "pilot_results.csv",
    index=False
)

print(df.head())
