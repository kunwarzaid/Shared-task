from openai import AzureOpenAI

# =====================================================
# CONFIG
# =====================================================

AZURE_ENDPOINT = "https://rni-openai-azure.openai.azure.com/"
AZURE_API_KEY = ""
AZURE_API_VERSION = "2024-02-01"
DEPLOYMENT_NAME = "gpt-4o"

INPUT_CSV = (
    "/home/coder/test/calibration_explain/"
    "generations.csv"
)
OUTPUT_CSV = (
    "/home/coder/test/calibration_explain/"
    "gpt_judge_results.csv"
)

MAX_RETRIES = 3
RETRY_DELAY = 5

# =====================================================
# AZURE CLIENT
# =====================================================

client = AzureOpenAI(
