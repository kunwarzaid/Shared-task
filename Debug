).head(5).iterrows():
    print(f"\nQ: {row['question']}")
    print(f"A: {row['greedy_answer']}")
    print(f"E: {row['explanation']}")
    print(
        f"GPT={row['gpt_perceived_uncertainty']:.0f} | "
        f"EBSE={row['norm_ebse']:.3f} | "
        f"len={row['expl_length']}"
    )
    print(f"Reason: {row['gpt_reason']}")

# =====================================================
# SAVE SUMMARY CSV
# =====================================================

summary_df = pd.DataFrame([{
    "n_scored": len(scored),
    "correct_pct": len(correct_df) / len(scored),
    "ebse_mean": scored["norm_ebse"].mean(),
