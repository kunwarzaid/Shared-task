# =====================================================
# FUNCTION 1: Embedding-Based Semantic Entropy
#
# IMPORTANT NOTE (per GPT critique):
# This is an embedding-based approximation of
# semantic entropy, NOT the Farquhar et al. method.
# Farquhar uses bidirectional NLI entailment for
# semantic equivalence. We use cosine similarity
# over sentence embeddings.
# This is clearly labeled as an approximation.
# For the paper, we will call it:
# "Embedding-Based Semantic Entropy (EBSE)"
#
# Changes from v1:
# - N_SAMPLES increased from 5 to 10
# - Greedy cosine clustering replaced with
#   AgglomerativeClustering (order-independent)
# - cluster_sizes now saved for debugging
# =====================================================

def compute_embedding_semantic_entropy(question, idx):

    prompt = f"""Answer the following question in one sentence.

Question: {question}

Answer:"""

    inputs = tokenizer(
        prompt,
        return_tensors="pt"
    ).to(model.device)

    # Generate N_SAMPLES answers with temperature
    with torch.no_grad():
        outputs = model.generate(
            **inputs,
            max_new_tokens=60,
            do_sample=True,
            temperature=TEMPERATURE,
            num_return_sequences=N_SAMPLES,
            pad_token_id=tokenizer.eos_token_id
        )

    # Decode all samples
    answers = []
    for seq in outputs:
        generated = seq[inputs.input_ids.shape[1]:]
        text = tokenizer.decode(
            generated, skip_special_tokens=True
        ).strip()
        answers.append(text)

    # Greedy answer for explanation generation
    with torch.no_grad():
        greedy_out = model.generate(
            **inputs,
            max_new_tokens=60,
            do_sample=False,
            pad_token_id=tokenizer.eos_token_id
        )
    greedy_tokens = greedy_out[0][
        inputs.input_ids.shape[1]:
    ]
    greedy_answer = tokenizer.decode(
        greedy_tokens, skip_special_tokens=True
    ).strip()

    # Encode answers into embeddings
    embeddings = encoder.encode(answers)

    # Agglomerative clustering — order independent
    # Uses cosine distance = 1 - cosine similarity
    if len(answers) > 1:
        clustering = AgglomerativeClustering(
            n_clusters=None,
            distance_threshold=CLUSTER_DISTANCE_THRESHOLD,
            metric='cosine',
            linkage='average'
        )
        labels = clustering.fit_predict(embeddings)
    else:
        labels = np.array([0])

    # Build clusters from labels
    n_clusters = len(set(labels))
    cluster_dict = {}
    for i, label in enumerate(labels):
        if label not in cluster_dict:
            cluster_dict[label] = []
        cluster_dict[label].append(i)

    clusters = list(cluster_dict.values())
    cluster_sizes = [len(c) for c in clusters]
    cluster_answers = [answers[c[0]] for c in clusters]

    # Cluster probabilities = fraction of samples
    cluster_probs = np.array(
        [len(c) / N_SAMPLES for c in clusters]
    )

    # Embedding-based semantic entropy
    epsilon = 1e-10
    ebse = -np.sum(
        cluster_probs * np.log(cluster_probs + epsilon)
    )

    # Normalize by log(N_SAMPLES)
    max_ebse = np.log(N_SAMPLES)
    norm_ebse = ebse / max_ebse if max_ebse > 0 else 0.0

    # Sanity check print for first INSPECT_FIRST_N
    if idx < INSPECT_FIRST_N:
        print(f"\n  [Sanity Check idx={idx}]")
        print(f"  Question: {question}")
        print(f"  Sampled answers:")
        for i, a in enumerate(answers):
            print(f"    [{i}] {a}")
        print(f"  Clusters ({n_clusters}):")
        for i, (ca, cs) in enumerate(
            zip(cluster_answers, cluster_sizes)
        ):
            print(f"    Cluster {i}: '{ca}' (size={cs})")
        print(f"  EBSE={ebse:.4f} | norm={norm_ebse:.4f}")

    return (
        greedy_answer,
        answers,
        ebse,
        norm_ebse,
        n_clusters,
        cluster_answers,
        cluster_sizes
    )

# =====================================================
# FUNCTION 2: Explanation + Communicated Uncertainty
# Method A (baseline) + Method B (primary)
# Float32 cast throughout to prevent NaN
# =====================================================

def get_explanation_communicated_uncertainty(
    question, answer
):

    prompt = f"""Question: {question}

Answer: {answer}

Provide an explanation for this answer:"""

    inputs = tokenizer(
        prompt,
        return_tensors="pt"
    ).to(model.device)

    with torch.no_grad():
        output = model.generate(
            **inputs,
            max_new_tokens=100,
            do_sample=False,
            return_dict_in_generate=True,
            output_scores=True,
            pad_token_id=tokenizer.eos_token_id
        )

    generated_tokens = output.sequences[0][
        inputs.input_ids.shape[1]:
    ]

    explanation = tokenizer.decode(
        generated_tokens, skip_special_tokens=True
    ).strip()

    # Precompute tensor versions of ID sets
    certainty_ids_tensor = torch.tensor(
        list(CERTAINTY_IDS), device=model.device
    )
    uncertainty_ids_tensor = torch.tensor(
        list(UNCERTAINTY_IDS), device=model.device
    )

    # Method A: generated token lexicon match
    certainty_mass_A = 0.0
    uncertainty_mass_A = 0.0
    certain_count_A = 0
    hedge_count_A = 0

    # Method B: probability mass over full lexicon
    # at every position
    certainty_mass_B = 0.0
    uncertainty_mass_B = 0.0
    n_positions = 0

    for token_id, scores in zip(
        generated_tokens, output.scores
    ):
        # Float32 cast — prevents NaN from float16
        probs = torch.softmax(
            scores[0].float(), dim=-1
        )
        token_id_item = token_id.item()

        # Method A
        if token_id_item in CERTAINTY_IDS:
            certainty_mass_A += probs[
                token_id_item
            ].item()
            certain_count_A += 1
        elif token_id_item in UNCERTAINTY_IDS:
            uncertainty_mass_A += probs[
                token_id_item
            ].item()
            hedge_count_A += 1

        # Method B
        if len(certainty_ids_tensor) > 0:
            certainty_mass_B += probs[
                certainty_ids_tensor
            ].sum().item()
        if len(uncertainty_ids_tensor) > 0:
            uncertainty_mass_B += probs[
                uncertainty_ids_tensor
            ].sum().item()

        n_positions += 1

    # Method A scores
    total_A = certainty_mass_A + uncertainty_mass_A
    is_neutral_A = 1 if total_A == 0 else 0
    if total_A == 0:
        comm_certainty_A = 0.5
        comm_uncertainty_A = 0.5
    else:
        comm_certainty_A = certainty_mass_A / total_A
        comm_uncertainty_A = 1 - comm_certainty_A

    # Method B scores
    if n_positions > 0:
        avg_cert_B = certainty_mass_B / n_positions
        avg_uncert_B = uncertainty_mass_B / n_positions
    else:
        avg_cert_B = 0.0
        avg_uncert_B = 0.0

    total_B = avg_cert_B + avg_uncert_B
    if total_B == 0:
        comm_certainty_B = 0.5
        comm_uncertainty_B = 0.5
    else:
        comm_certainty_B = avg_cert_B / total_B
        comm_uncertainty_B = 1 - comm_certainty_B

    return (
        explanation,
        comm_certainty_A, comm_uncertainty_A,
        certain_count_A, hedge_count_A, is_neutral_A,
        comm_certainty_B, comm_uncertainty_B,
        avg_cert_B, avg_uncert_B, n_positions
    )

# =====================================================
# CORRECTNESS CHECK
# =====================================================

STOP_WORDS = {
    'the', 'a', 'an', 'is', 'are', 'was', 'were',
    'of', 'in', 'to', 'and', 'or', 'it', 'its',
    'this', 'that', 'with', 'for', 'on', 'at', 'by'
}

def is_correct(answer, reference_answers):
    answer_words = set(answer.lower().split())
    for ref in reference_answers:
        ref_words = set(ref.lower().split())
        ref_content = ref_words - STOP_WORDS
        if len(ref_content) == 0:
            continue
        overlap = (
            len(answer_words & ref_content)
            / len(ref_content)
        )
        if overlap >= 0.5:
            return 1
    return 0

