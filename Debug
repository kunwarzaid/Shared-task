PAIRWISE_SYSTEM_PROMPT = """You are comparing two
explanations to determine which one communicates
MORE uncertainty to a reader.

Consider hedging language, acknowledgment of
alternatives, and overall confidence of tone.

Do NOT consider factual correctness.

Respond with ONLY one of the following:
A
B"""

PAIRWISE_USER_TEMPLATE = """Explanation A:
{explanation_a}

Explanation B:
{explanation_b}

Which explanation communicates MORE uncertainty?
Respond with only "A" or "B"."""

# =====================================================
# FUNCTION: Absolute scoring judge
# =====================================================

def judge_explanation(question, answer, explanation):
   """
   Ask GPT to score the PERCEIVED communicated
   uncertainty of a single explanation.
   Returns (score, reason, raw_response).
   """

   user_message = USER_TEMPLATE.format(
       question=question,
       answer=answer,
       explanation=explanation
   )

   for attempt in range(MAX_RETRIES):
       try:
           response = client.chat.completions.create(
               model=DEPLOYMENT_NAME,
               messages=[
                   {
                       "role": "system",
                       "content": SYSTEM_PROMPT
                   },
                   {
                       "role": "user",
                       "content": user_message
                   }
               ],
               temperature=0.0,
               max_tokens=200
           )

           raw = response.choices[0].message.content.strip()
           clean = raw.replace(
               "```json", ""
           ).replace("```", "").strip()
           parsed = json.loads(clean)

           score = int(parsed["uncertainty_score"])
           reason = parsed.get("reason", "")
           score = max(0, min(100, score))

           return score, reason, raw

       except json.JSONDecodeError as e:
           print(
               f"  JSON parse error attempt "
               f"{attempt+1}: {e}"
           )
           if attempt < MAX_RETRIES - 1:
               time.sleep(RETRY_DELAY)
           else:
               return None, "JSON parse failed", ""

       except Exception as e:
           print(
               f"  API error attempt {attempt+1}: {e}"
           )
           if attempt < MAX_RETRIES - 1:
               time.sleep(RETRY_DELAY)
           else:
               return None, f"API error: {e}", ""

   return None, "Max retries exceeded", ""

# =====================================================
# FUNCTION: Pairwise ranking judge
# =====================================================

def pairwise_judge(explanation_a, explanation_b):
   """
   Ask GPT which explanation sounds more uncertain.
   Returns 'A', 'B', or None on failure.
   """

   user_message = PAIRWISE_USER_TEMPLATE.format(
       explanation_a=explanation_a,
       explanation_b=explanation_b
   )

   for attempt in range(MAX_RETRIES):
       try:
           response = client.chat.completions.create(
               model=DEPLOYMENT_NAME,
               messages=[
                   {
                       "role": "system",
                       "content": PAIRWISE_SYSTEM_PROMPT
                   },
                   {
                       "role": "user",
                       "content": user_message
                   }
               ],
               temperature=0.0,
               max_tokens=5
           )

           raw = response.choices[0].message.content.strip().upper()

           if "A" in raw and "B" not in raw:
               return "A"
           elif "B" in raw and "A" not in raw:
               return "B"
           else:
               if attempt < MAX_RETRIES - 1:
                   time.sleep(RETRY_DELAY)
                   continue
               return None

       except Exception as e:
           print(
               f"  Pairwise API error attempt "
               f"{attempt+1}: {e}"
           )
           if attempt < MAX_RETRIES - 1:
               time.sleep(RETRY_DELAY)
           else:
               return None

   return None

