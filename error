import os
import json
import zipfile
import requests
import pandas as pd
from pathlib import Path

# -------------------------
# CONFIG
# -------------------------

WRAPPER_URL = "https://openai-wrapper-adf0awcrcjghg3cz.southindia-01.azurewebsites.net/openai_service"
MODEL = "gpt-5"
EMPLOYEE_ID = "1757421"

FINETUNE_ZIP = "finetune.zip"
TEST_ZIP = "test.zip"

DATA_DIR = "data_eval"
MAX_TOKENS = 1200


# -------------------------
# GPT CALL
# -------------------------

def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are a strict medical summary faithfulness evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": MAX_TOKENS,
        "employeeId": EMPLOYEE_ID
    }

    r = requests.post(WRAPPER_URL, json=payload)

    try:
        return r.json()["choices"][0]["message"]["content"]
    except:
        return ""


# -------------------------
# UNZIP DATA
# -------------------------

def unzip_data():

    os.makedirs(DATA_DIR, exist_ok=True)

    with zipfile.ZipFile(FINETUNE_ZIP, 'r') as z:
        z.extractall(DATA_DIR)

    with zipfile.ZipFile(TEST_ZIP, 'r') as z:
        z.extractall(DATA_DIR)

    print("Data extracted")


# -------------------------
# LOAD DIALOGUE
# -------------------------

def load_dialogue(path):

    lines = []

    with open(path, "r", encoding="utf-8") as f:

        for line in f:
            obj = json.loads(line)

            speaker = obj.get("speaker", "")
            text = obj.get("dialogue", "")

            lines.append(f"{speaker}: {text}")

    return "\n".join(lines)


# -------------------------
# LOAD SUMMARY
# -------------------------

def load_summary(path):

    with open(path, "r", encoding="utf-8") as f:
        return f.read()


# -------------------------
# BUILD PROMPT
# -------------------------

def build_prompt(dialogue, summary):

    return f"""
Evaluate factual faithfulness of the summary with respect to the dialogue.

Steps:
1 Extract atomic facts from the summary
2 Verify each fact against the dialogue
3 Mark unsupported facts as hallucinated

Dialogue:
{dialogue}

Summary:
{summary}

Return JSON ONLY:

{{
 "supported_count": int,
 "hallucinated_count": int,
 "hallucinated_facts": ["fact1","fact2"],
 "faithfulness_score": float
}}
"""


# -------------------------
# COLLECT FILE PAIRS
# -------------------------

def collect_pairs():

    pairs = []

    langs = ["English", "Hindi", "Marathi", "Bangla"]

    for lang in langs:

        summary_dir = Path(DATA_DIR) / "finetune" / lang / "Summary_Text"
        dialogue_dir = Path(DATA_DIR) / "test" / lang / "Dialogues"

        if not summary_dir.exists():
            continue

        for s in summary_dir.glob("*_summary.txt"):

            base_name = s.stem.replace("_summary", "")

            dialogue_file = dialogue_dir / f"{base_name}.jsonl"

            if dialogue_file.exists():

                pairs.append({
                    "language": lang,
                    "summary": s,
                    "dialogue": dialogue_file
                })

    print("Total pairs found:", len(pairs))

    return pairs


# -------------------------
# EVALUATE FILE
# -------------------------

def evaluate(dialogue_path, summary_path):

    dialogue = load_dialogue(dialogue_path)
    summary = load_summary(summary_path)

    prompt = build_prompt(dialogue, summary)

    result = call_gpt(prompt)

    try:
        return json.loads(result)
    except:
        return {
            "supported_count": 0,
            "hallucinated_count": 0,
            "faithfulness_score": 0
        }


# -------------------------
# MAIN
# -------------------------

def run():

    unzip_data()

    pairs = collect_pairs()

    rows = []

    for p in pairs:

        print("Evaluating:", p["summary"].name)

        res = evaluate(p["dialogue"], p["summary"])

        rows.append({
            "language": p["language"],
            "file": p["summary"].name,
            "supported": res.get("supported_count", 0),
            "hallucinated": res.get("hallucinated_count", 0),
            "faithfulness": res.get("faithfulness_score", 0)
        })

    df = pd.DataFrame(rows)

    if df.empty:
        print("No results generated. Check file matching.")
        return

    df.to_csv("file_level_results.csv", index=False)

    lang_table = df.groupby("language").agg(
        files=("file", "count"),
        avg_faithfulness=("faithfulness", "mean"),
        hallucinated_total=("hallucinated", "sum")
    ).reset_index()

    lang_table.to_csv("language_summary.csv", index=False)

    overall_score = df["faithfulness"].mean()

    print("\nOverall Faithfulness:", round(overall_score, 3))


if __name__ == "__main__":
    run()
