import os
import json
import zipfile
import requests
import pandas as pd
import re
from pathlib import Path

# =====================
# CONFIG
# =====================

WRAPPER_URL = "https://openai-wrapper-adf0awcrcjghg3cz.southindia-01.azurewebsites.net/openai_service"
MODEL = "gpt-5"
EMPLOYEE_ID = "1757421"

FINETUNE_ZIP = "finetune.zip"
TEST_ZIP = "test.zip"

DATA_DIR = "data_eval"
DEBUG_FILES = 3


# =====================
# GPT CALL
# =====================

def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are an expert clinical summarization evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": 800,
        "employeeId": EMPLOYEE_ID
    }

    try:

        response = requests.post(
            WRAPPER_URL,
            json=payload,
            timeout=120
        )

        data = response.json()

        return data["choices"][0]["message"]["content"]

    except Exception as e:

        print("GPT call failed:", e)
        return ""


# =====================
# JSON PARSER
# =====================

def extract_json(text):

    try:
        return json.loads(text)
    except:
        pass

    match = re.search(r"\{.*\}", text, re.DOTALL)

    if match:
        try:
            return json.loads(match.group())
        except:
            pass

    return None


# =====================
# UNZIP DATA
# =====================

def unzip_data():

    os.makedirs(DATA_DIR, exist_ok=True)

    with zipfile.ZipFile(FINETUNE_ZIP) as z:
        z.extractall(DATA_DIR)

    with zipfile.ZipFile(TEST_ZIP) as z:
        z.extractall(DATA_DIR)

    print("Data extracted")


# =====================
# LOAD DIALOGUE
# =====================

def load_dialogue(path):

    lines = []

    with open(path, encoding="utf-8") as f:

        for line in f:

            line=line.strip()

            if not line:
                continue

            try:

                obj=json.loads(line)

                speaker=obj.get("speaker","")
                text=obj.get("dialogue","")

                lines.append(f"{speaker}: {text}")

            except:
                continue

    return "\n".join(lines)


# =====================
# LOAD SUMMARY
# =====================

def load_summary(path):

    with open(path,encoding="utf-8") as f:
        return f.read()


# =====================
# PROMPT
# =====================

def build_prompt(dialogue,summary):

    return f"""
Evaluate factual faithfulness of the summary with respect to the dialogue.

Steps:
1 Extract factual claims from the summary.
2 Check if each claim is supported by the dialogue.
3 Provide supporting evidence if present.

Dialogue:
{dialogue}

Summary:
{summary}

Return JSON:

{{
 "claims":[
   {{
     "claim":"",
     "supported":true/false,
     "evidence":""
   }}
 ],
 "supported_count":0,
 "hallucinated_count":0,
 "faithfulness_score":0
}}
"""


# =====================
# COLLECT FILE PAIRS
# =====================

def collect_pairs():

    pairs=[]

    langs=["English","Hindi","Marathi","Bangla"]

    for lang in langs:

        summary_dir=Path(DATA_DIR)/"finetune"/lang/"Summary_Text"
        dialogue_dir=Path(DATA_DIR)/"test"/lang/"Dialogues"

        if not summary_dir.exists():
            continue

        for s in summary_dir.glob("*_summary.txt"):

            base=s.stem.replace("_summary","")

            d=dialogue_dir/f"{base}.jsonl"

            if d.exists():

                pairs.append({
                    "language":lang,
                    "summary":s,
                    "dialogue":d
                })

    print("Total pairs:",len(pairs))

    return pairs


# =====================
# EVALUATION
# =====================

def evaluate(pair,debug=False):

    summary=load_summary(pair["summary"])
    dialogue=load_dialogue(pair["dialogue"])

    prompt=build_prompt(dialogue,summary)

    raw=call_gpt(prompt)

    parsed=extract_json(raw)

    if parsed:

        if debug:

            print("\nDEBUG FILE:",pair["summary"].name)
            print("GPT OUTPUT:",raw[:800])

        return {
            "language":pair["language"],
            "file":pair["summary"].name,
            "supported":parsed.get("supported_count",0),
            "hallucinated":parsed.get("hallucinated_count",0),
            "faithfulness":parsed.get("faithfulness_score",0)
        }

    return {
        "language":pair["language"],
        "file":pair["summary"].name,
        "supported":0,
        "hallucinated":0,
        "faithfulness":0
    }


# =====================
# MAIN
# =====================

def run():

    unzip_data()

    pairs=collect_pairs()

    results=[]

    for i,p in enumerate(pairs):

        debug=True if i<DEBUG_FILES else False

        res=evaluate(p,debug)

        results.append(res)

        print("Completed:",i+1,"/",len(pairs))

    df=pd.DataFrame(results)

    df.to_csv("file_level_results.csv",index=False)

    lang_table=df.groupby("language").agg(
        files=("file","count"),
        avg_faithfulness=("faithfulness","mean"),
        hallucinated_total=("hallucinated","sum")
    ).reset_index()

    lang_table.to_csv("language_summary.csv",index=False)

    print("\nOverall Faithfulness:",round(df["faithfulness"].mean(),3))


if __name__=="__main__":
    run()
