def query_model(
    model: str,
    user_prompt: str,
    system_prompt: Optional[str] = None,
    image_bytes: Optional[bytes] = None,
    image_mime_type: Optional[str] = None,
    pdf_text: Optional[str] = None,
    tries: int = 2,
    timeout_val_for_retry: float = 2.0,
) -> str:

    payload = {
        "model": model,
        "prompt": [
            {"role": "system", "content": system_prompt or ""},
            {"role": "user", "content": user_prompt}
        ],
        "max_tokens": 1024,
        "employeeId": "1757421"
    }

    for attempt in range(tries):

        try:

            response = requests.post(
                AZURE_WRAPPER_URL,
                json=payload,
                timeout=120
            )

            data = response.json()

            # wrapper response format
            if "response" in data:
                ans = data["response"]

            elif "choices" in data:
                ans = data["choices"][0]["message"]["content"]

            else:
                ans = str(data)

            return ans.strip()

        except Exception as ex:

            log_trace(
                f"Error in Azure query_model (attempt {attempt+1}/{tries}): {ex}",
                "ERROR",
            )

            if attempt < tries - 1:
                time.sleep(timeout_val_for_retry)

    return "ERROR: LLM query failed"
