import os
import json
import zipfile
import requests
import pandas as pd
from pathlib import Path

WRAPPER_URL = "https://openai-wrapper-adf0awcrcjghg3cz.southindia-01.azurewebsites.net/openai_service"
MODEL = "gpt-5"
EMPLOYEE_ID = "1757421"

FINETUNE_ZIP = "finetune.zip"
TEST_ZIP = "test.zip"

DATA_DIR = "data_eval"

MAX_TOKENS = 800


# ----------------------
# GPT CALL
# ----------------------

def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are a clinical claim verification system."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": MAX_TOKENS,
        "employeeId": EMPLOYEE_ID
    }

    r = requests.post(WRAPPER_URL, json=payload)

    try:
        return r.json()["choices"][0]["message"]["content"]
    except:
        return ""


# ----------------------
# UNZIP DATA
# ----------------------

def unzip_data():

    os.makedirs(DATA_DIR, exist_ok=True)

    with zipfile.ZipFile(FINETUNE_ZIP) as z:
        z.extractall(DATA_DIR)

    with zipfile.ZipFile(TEST_ZIP) as z:
        z.extractall(DATA_DIR)

    print("Data extracted")


# ----------------------
# LOAD DIALOGUE
# ----------------------

def load_dialogue(path):

    lines = []

    with open(path, encoding="utf-8") as f:

        for line in f:

            line = line.strip()

            if not line:
                continue

            try:

                obj = json.loads(line)

                lines.append(
                    f"{obj.get('speaker','')}: {obj.get('dialogue','')}"
                )

            except:
                continue

    return "\n".join(lines)


# ----------------------
# LOAD SUMMARY
# ----------------------

def load_summary(path):

    with open(path, encoding="utf-8") as f:
        return f.read()


# ----------------------
# CLAIM EXTRACTION
# ----------------------

def extract_claims(summary):

    prompt = f"""
Extract atomic factual claims from the summary.

Summary:
{summary}

Return JSON list.
"""

    result = call_gpt(prompt)

    try:
        return json.loads(result)
    except:
        return []


# ----------------------
# VERIFY CLAIMS (BATCH)
# ----------------------

def verify_claims(dialogue, claims):

    prompt = f"""
Check whether each claim is supported by the dialogue.

Dialogue:
{dialogue}

Claims:
{claims}

Return JSON list:

[
 {{ "claim": "...", "supported": true }},
 {{ "claim": "...", "supported": false }}
]
"""

    result = call_gpt(prompt)

    try:
        return json.loads(result)
    except:
        return []


# ----------------------
# FILE MATCHING
# ----------------------

def collect_pairs():

    pairs = []

    langs = ["English","Hindi","Marathi","Bangla"]

    for lang in langs:

        summary_dir = Path(DATA_DIR)/"finetune"/lang/"Summary_Text"
        dialogue_dir = Path(DATA_DIR)/"test"/lang/"Dialogues"

        if not summary_dir.exists():
            continue

        for s in summary_dir.glob("*_summary.txt"):

            base = s.stem.replace("_summary","")

            d = dialogue_dir / f"{base}.jsonl"

            if d.exists():

                pairs.append({
                    "language":lang,
                    "summary":s,
                    "dialogue":d
                })

    print("Total pairs:", len(pairs))

    return pairs


# ----------------------
# MAIN
# ----------------------

def run():

    unzip_data()

    pairs = collect_pairs()

    file_rows = []
    claim_rows = []

    for p in pairs:

        print("Processing:", p["summary"].name)

        dialogue = load_dialogue(p["dialogue"])
        summary = load_summary(p["summary"])

        claims = extract_claims(summary)

        results = verify_claims(dialogue, claims)

        supported = 0

        for r in results:

            claim = r.get("claim","")
            is_supported = r.get("supported",False)

            if is_supported:
                supported += 1

            claim_rows.append({
                "language":p["language"],
                "file":p["summary"].name,
                "claim":claim,
                "supported":is_supported
            })

        total = len(results)

        faithfulness = supported/total if total else 0

        file_rows.append({
            "language":p["language"],
            "file":p["summary"].name,
            "claims":total,
            "supported":supported,
            "hallucinated":total-supported,
            "faithfulness":faithfulness
        })

    df_files = pd.DataFrame(file_rows)
    df_claims = pd.DataFrame(claim_rows)

    df_files.to_csv("file_level_results.csv",index=False)
    df_claims.to_csv("claim_level_results.csv",index=False)

    lang_table = df_files.groupby("language").agg(
        files=("file","count"),
        avg_faithfulness=("faithfulness","mean"),
        hallucinated_total=("hallucinated","sum")
    ).reset_index()

    lang_table.to_csv("language_summary.csv",index=False)

    print("\nOverall Faithfulness:", df_files["faithfulness"].mean())


if __name__ == "__main__":
    run()
