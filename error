BASE_MODEL = "Qwen/Qwen2.5-7B-Instruct"

ADAPTER_DIR = "/workspace/data/KZ_2117574/EACL/mistral_7b_finetune"

TEST_DIR = "/workspace/data/KZ_2117574/SharedTask_NLPAI4Health_Train&dev_set/test"

OUTPUT_DIR = "/workspace/data/KZ_2117574/EACL/Mistral_exp/finetune"

TARGET_LANGS = ["Bangla", "English", "Hindi", "Marathi"]

MAX_CONTEXT = 8192
MAX_NEW_TOKENS_SUMMARY = 1000


# ============================================================
# SYSTEM PROMPT
# ============================================================

SYSTEM_SUMMARY = (
    "You are a clinical documentation assistant. "
    "Your task is to generate faithful clinical summaries from doctor–patient dialogues."
    "You must only use information explicitly mentioned in the dialogue. "
    "Do not infer diagnoses or treatments that are not stated. "
    "Always preserve negations such as 'denies fever'. "
    "Write summaries in English regardless of the dialogue language. "
    "End the summary with the token <<END>>."
)


# ============================================================
# UTILS
# ============================================================

def tprint(msg):
    print(f"[{time.strftime('%H:%M:%S')}] {msg}", flush=True)


def safe_read_jsonl(path):

    rows = []

    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            try:
                rows.append(json.loads(line))
            except:
                continue

    return rows


def write_text(path, text):

    path.parent.mkdir(parents=True, exist_ok=True)

    with open(path, "w", encoding="utf-8") as f:
        f.write(text.strip() + "\n")


def build_messages(system_prompt, user_prompt):

    return [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_prompt},
    ]


# ============================================================
# MODEL LOADING
# ============================================================

def load_model():

    tprint("Loading tokenizer")

    tokenizer = AutoTokenizer.from_pretrained(
        BASE_MODEL,
        trust_remote_code=True
    )

    tokenizer.pad_token = tokenizer.eos_token

    quant_cfg = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_compute_dtype=torch.float16
    )

    tprint("Loading base model")

    base_model = AutoModelForCausalLM.from_pretrained(
        BASE_MODEL,
        device_map="auto",
        quantization_config=quant_cfg,
        torch_dtype=torch.float16,
        trust_remote_code=True
    )

    tprint("Loading LoRA adapter")

    model = PeftModel.from_pretrained(
        base_model,
        ADAPTER_DIR,
        torch_dtype=torch.float16
    )

    model.eval()
    model.config.use_cache = True

    return model, tokenizer


# ============================================================
# GENERATION
# ============================================================

def chat_generate(model, tokenizer, messages):

    prompt = tokenizer.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True
    )

    ids = tokenizer.encode(prompt, add_special_tokens=False)

    if len(ids) > MAX_CONTEXT:
        ids = ids[-MAX_CONTEXT:]
        prompt = tokenizer.decode(ids, skip_special_tokens=True)

    inputs = tokenizer([prompt], return_tensors="pt").to(model.device)

    with torch.no_grad():

        output = model.generate(
            **inputs,
            max_new_tokens=MAX_NEW_TOKENS_SUMMARY,
            do_sample=False,
            num_beams=4,
            repetition_penalty=1.1,
            length_penalty=0.9,
            pad_token_id=tokenizer.eos_token_id
        )

    gen = output[0][len(inputs.input_ids[0]):]

    return tokenizer.decode(gen, skip_special_tokens=True).strip()


# ============================================================
# MAIN PIPELINE
# ============================================================

def run_summary():

    model, tokenizer = load_model()

    for lang_dir in Path(TEST_DIR).iterdir():

        if lang_dir.name not in TARGET_LANGS:
            continue

        tprint(f"Processing language: {lang_dir.name}")

        dlg_dir = lang_dir / "Dialogues"

        out_dir = Path(OUTPUT_DIR) / lang_dir.name / "Summary_Text"

        files = sorted(dlg_dir.glob("*.jsonl"))[:110]

        print_limit = 3
        printed = 0

        for f in tqdm(files, desc=lang_dir.name):

            out_file = out_dir / f"{f.stem}_summary.txt"

            if out_file.exists():
                continue

            rows = safe_read_jsonl(f)

            dialogue = " ".join(
                r.get("dialogue", "")
                for r in rows
                if isinstance(r, dict)
            )

            user_prompt = f"""
Below is a doctor–patient conversation.

The dialogue may be written in Hindi, Marathi, Bangla, or English.

Write a concise and faithful clinical summary only in English, do not use any other language in the summary.

Rules:
- Only include information explicitly mentioned.
- Do not infer diagnoses or medications.
- Preserve negations such as "denies fever".

Dialogue:
{dialogue}
"""

            summary = chat_generate(
                model,
                tokenizer,
                build_messages(SYSTEM_SUMMARY, user_prompt)
            )

            summary = summary.split("<<END>>")[0].strip()

            write_text(out_file, summary)

            # PRINT EXAMPLES
            if printed < print_limit:

                print("\n==============================")
                print("FILE:", f.name)

                print("\nDIALOGUE SAMPLE:\n")
                print(dialogue[:800])

                print("\nGENERATED SUMMARY:\n")
                print(summary)

                print("==============================\n")

                printed += 1

        torch.cuda.empty_cache()

    tprint("Inference completed.")


# ============================================================
# ENTRY POINT
# ============================================================

if __name__ == "__main__":
    run_summary()
