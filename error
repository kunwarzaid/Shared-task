BASE_MODEL = "Qwen/Qwen2.5-7B-Instruct"

TEST_DIR = "/workspace/data/KZ_2117574/SharedTask_NLPAI4Health_Train&dev_set/transliterated_dialogues/transliterated_dialogues"
OUTPUT_DIR = "/workspace/data/KZ_2117574/EACL/Qwen_2.5_7B_Instruct_translit_16k/summary_only"

TARGET_LANGS = ["Bangla", "English", "Hindi", "Marathi"]

CTX_MAX = 16000
MAX_NEW_TOKENS_SUMMARY = 1024

# ============================================================
# PROMPT
# ============================================================

ZERO_SHOT_PROMPT_TEMPLATE = """
You are a clinical documentation assistant.

{language_line}

Important: The dialogue may be written in Roman script (transliterated) and is NOT English even if it looks similar. Interpret it in the correct language.

Task: Write a clinical summary of the dialogue.

Rules:
- Use ONLY information explicitly stated in the dialogue.
- Do NOT infer, assume, or add missing details.
- Do NOT introduce diagnoses, medications, or durations unless explicitly mentioned.
- Preserve negations exactly.
- If information is not present, do not include it.
- If unsure about any detail, omit it.
- Do NOT translate or reinterpret the dialogue.

Write a clear, complete, and concise clinical summary.

Output:
[Summary]
<summary>

Dialogue:
{dialogue}
"""

# ============================================================
# UTILS
# ============================================================

def tprint(msg):
    print(f"[{time.strftime('%H:%M:%S')}] {msg}", flush=True)

def safe_read_jsonl(path):
    rows = []
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            try:
                rows.append(json.loads(line.strip()))
            except:
                continue
    return rows

def write_text(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text.strip() + "\n", encoding="utf-8")

def normalize_transliterated(text):
    text = text.lower()
    replacements = {
        "kr": "kar",
        "rha": "raha",
        "hn": "haan"
    }
    for k, v in replacements.items():
        text = re.sub(rf"\b{k}\b", v, text)
    return text

def count_tokens(tokenizer, text):
    return len(tokenizer.encode(text, add_special_tokens=False))

# ============================================================
# MODEL
# ============================================================

def load_model():
    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL, use_fast=True)
    tokenizer.pad_token = tokenizer.eos_token

    quant_cfg = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_compute_dtype=torch.float16
    )

    model = AutoModelForCausalLM.from_pretrained(
        BASE_MODEL,
        device_map="auto",
        quantization_config=quant_cfg,
        torch_dtype=torch.float16
    )

    model.eval()
    return model, tokenizer

# ============================================================
# GENERATION
# ============================================================

def chat_generate(model, tokenizer, messages):
    prompt = tokenizer.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True
    )

    inputs = tokenizer(
        prompt,
        return_tensors="pt",
        truncation=False
    ).to(model.device)

    with torch.no_grad():
        output = model.generate(
            **inputs,
            max_new_tokens=MAX_NEW_TOKENS_SUMMARY,
            do_sample=False,
            temperature=0.0,
            num_beams=1,
            pad_token_id=tokenizer.eos_token_id,
            eos_token_id=tokenizer.eos_token_id
        )

    gen_ids = output[0][inputs.input_ids.shape[-1]:]
    return tokenizer.decode(gen_ids, skip_special_tokens=True).strip(), prompt

# ============================================================
# MAIN PIPELINE
# ============================================================

def run_summary_only():
    model, tokenizer = load_model()

    skipped = 0
    processed = 0

    langs = [
        p for p in Path(TEST_DIR).iterdir()
        if p.is_dir() and p.name in TARGET_LANGS
    ]

    for lang_dir in langs:
        lang = lang_dir.name
        tprint(f"Processing language: {lang}")

        dlg_dir = lang_dir / "Dialogues"
        out_dir = Path(OUTPUT_DIR) / lang / "Summary_Text"

        files = sorted(dlg_dir.glob("*.jsonl"))

        for f in tqdm(files, desc=lang):
            out_file = out_dir / f"{f.stem}_summary.txt"
            if out_file.exists():
                continue

            rows = safe_read_jsonl(f)

            dialogue = " ".join(
                r.get("dialogue", "") for r in rows if isinstance(r, dict)
            )

            # Normalize transliterated text
            if lang != "English":
                dialogue = normalize_transliterated(dialogue)

            # Language-aware instruction
            if lang == "English":
                language_line = "The dialogue is in English."
            else:
                language_line = f"The dialogue is written in Roman script and represents spoken {lang} (Romanized {lang}), possibly mixed with English."

            user_prompt = ZERO_SHOT_PROMPT_TEMPLATE.format(
                dialogue=dialogue,
                language_line=language_line
            )

            messages = [{"role": "user", "content": user_prompt}]

            # ============================
            # CTX CHECK (16K SAFE)
            # ============================

            prompt_text = tokenizer.apply_chat_template(
                messages,
                tokenize=False,
                add_generation_prompt=True
            )

            input_tokens = count_tokens(tokenizer, prompt_text)

            if input_tokens + MAX_NEW_TOKENS_SUMMARY > CTX_MAX:
                skipped += 1
                print(f"[SKIPPED] {f.name} | tokens={input_tokens}")
                continue

            try:
                summary, _ = chat_generate(model, tokenizer, messages)
                write_text(out_file, summary)
                processed += 1

            except RuntimeError as e:
                print(f"[ERROR] {f.name}: {e}")
                torch.cuda.empty_cache()
                continue

        torch.cuda.empty_cache()

    tprint(f"Done. Processed={processed}, Skipped={skipped}")

# ============================================================
# ENTRY POINT
# ============================================================

if __name__ == "__main__":
    run_summary_only()
