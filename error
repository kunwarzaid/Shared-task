def load_jsonl(path):

    rows = []

    with open(path, "r", encoding="utf-8", errors="replace") as f:

        for line in f:

            line = line.strip()

            if not line:
                continue

            try:
                rows.append(json.loads(line))

            except json.JSONDecodeError:
                # skip malformed lines
                continue

    return rows
