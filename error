import os
import json
import zipfile
import requests
import pandas as pd
import re
from pathlib import Path

# =========================
# CONFIG
# =========================

WRAPPER_URL = "https://openai-wrapper-adf0awcrcjghg3cz.southindia-01.azurewebsites.net/openai_service"
MODEL = "gpt-5"
EMPLOYEE_ID = "1757421"

FINETUNE_ZIP = "finetune.zip"
TEST_ZIP = "test.zip"

DATA_DIR = "data_eval"

CHUNK_SIZE = 40   # dialogue lines per chunk
DEBUG_FILES = 3


# =========================
# GPT CALL
# =========================

def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are a clinical summarization evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": 600,
        "employeeId": EMPLOYEE_ID
    }

    for attempt in range(3):

        try:

            r = requests.post(
                WRAPPER_URL,
                json=payload,
                timeout=120
            )

            if r.status_code == 200:
                return r.text

        except Exception as e:

            print("Retry", attempt+1, "failed:", e)

    return ""


# =========================
# JSON EXTRACTOR
# =========================

def extract_json(text):

    try:
        return json.loads(text)
    except:
        pass

    match = re.search(r"\{.*\}", text, re.DOTALL)

    if match:
        try:
            return json.loads(match.group())
        except:
            pass

    return None


# =========================
# UNZIP DATA
# =========================

def unzip_data():

    os.makedirs(DATA_DIR, exist_ok=True)

    with zipfile.ZipFile(FINETUNE_ZIP) as z:
        z.extractall(DATA_DIR)

    with zipfile.ZipFile(TEST_ZIP) as z:
        z.extractall(DATA_DIR)

    print("Data extracted")


# =========================
# LOAD DIALOGUE
# =========================

def load_dialogue(path):

    lines = []

    with open(path, encoding="utf-8") as f:

        for line in f:

            line = line.strip()

            if not line:
                continue

            try:

                obj = json.loads(line)

                speaker = obj.get("speaker","")
                text = obj.get("dialogue","")

                lines.append(f"{speaker}: {text}")

            except:
                continue

    return lines


# =========================
# LOAD SUMMARY
# =========================

def load_summary(path):

    with open(path, encoding="utf-8") as f:
        return f.read()


# =========================
# SPLIT DIALOGUE INTO CHUNKS
# =========================

def chunk_dialogue(lines):

    chunks = []

    for i in range(0, len(lines), CHUNK_SIZE):

        chunk = "\n".join(lines[i:i+CHUNK_SIZE])

        chunks.append(chunk)

    return chunks


# =========================
# CLAIM EXTRACTION
# =========================

def extract_claims(summary):

    prompt = f"""
Extract factual claims from the summary.

Summary:
{summary}

Return JSON:

{{
 "claims":[]
}}
"""

    raw = call_gpt(prompt)

    parsed = extract_json(raw)

    if parsed and "claims" in parsed:

        return parsed["claims"]

    return []


# =========================
# VERIFY CLAIMS IN CHUNK
# =========================

def verify_chunk(claims, chunk):

    prompt = f"""
Check which claims are supported by the dialogue chunk.

Dialogue chunk:
{chunk}

Claims:
{claims}

Return JSON:

{{
 "supported":[]
}}
"""

    raw = call_gpt(prompt)

    parsed = extract_json(raw)

    if parsed and "supported" in parsed:

        return parsed["supported"]

    return []


# =========================
# FILE MATCHING
# =========================

def collect_pairs():

    pairs = []

    langs = ["English","Hindi","Marathi","Bangla"]

    for lang in langs:

        summary_dir = Path(DATA_DIR)/"finetune"/lang/"Summary_Text"
        dialogue_dir = Path(DATA_DIR)/"test"/lang/"Dialogues"

        if not summary_dir.exists():
            continue

        for s in summary_dir.glob("*_summary.txt"):

            base = s.stem.replace("_summary","")

            d = dialogue_dir / f"{base}.jsonl"

            if d.exists():

                pairs.append({
                    "language":lang,
                    "summary":s,
                    "dialogue":d
                })

    print("Total pairs:", len(pairs))

    return pairs


# =========================
# EVALUATE ONE FILE
# =========================

def evaluate(pair, debug=False):

    summary = load_summary(pair["summary"])

    dialogue_lines = load_dialogue(pair["dialogue"])

    chunks = chunk_dialogue(dialogue_lines)

    claims = extract_claims(summary)

    remaining_claims = claims.copy()

    supported_claims = []

    for chunk in chunks:

        if not remaining_claims:
            break

        supported = verify_chunk(remaining_claims, chunk)

        for c in supported:

            if c in remaining_claims:

                supported_claims.append(c)

                remaining_claims.remove(c)

    total = len(claims)

    supported_count = len(supported_claims)

    hallucinated = len(remaining_claims)

    faithfulness = supported_count / total if total > 0 else 0

    if debug:

        print("\n======== DEBUG ========")
        print("FILE:", pair["summary"].name)
        print("Claims:", claims)
        print("Supported:", supported_claims)
        print("Hallucinated:", remaining_claims)

    return {
        "language":pair["language"],
        "file":pair["summary"].name,
        "supported":supported_count,
        "hallucinated":hallucinated,
        "faithfulness":faithfulness
    }


# =========================
# MAIN
# =========================

def run():

    unzip_data()

    pairs = collect_pairs()

    results = []

    for i,p in enumerate(pairs):

        debug = True if i < DEBUG_FILES else False

        res = evaluate(p, debug)

        results.append(res)

        print("Completed:", i+1, "/", len(pairs))

    df = pd.DataFrame(results)

    df.to_csv("file_level_results.csv", index=False)

    lang_table = df.groupby("language").agg(
        files=("file","count"),
        avg_faithfulness=("faithfulness","mean"),
        hallucinated_total=("hallucinated","sum")
    ).reset_index()

    lang_table.to_csv("language_summary.csv", index=False)

    print("\nOverall Faithfulness:", round(df["faithfulness"].mean(),3))


if __name__ == "__main__":
    run()
