def tokenize(example):

    try:
        prompt_text = build_prompt(example["dialogue"])

        messages = [
            {"role": "system", "content": "You are a clinical documentation assistant."},
            {"role": "user", "content": prompt_text}
        ]

        prompt = tokenizer.apply_chat_template(
            messages,
            tokenize=False,
            add_generation_prompt=True
        )

        summary = example["summary"] + tokenizer.eos_token

        prompt_ids = tokenizer.encode(prompt, add_special_tokens=False)
        summary_ids = tokenizer.encode(summary, add_special_tokens=False)

        if len(prompt_ids) + len(summary_ids) > CTX_MAX:
            return {
                "input_ids": [],
                "attention_mask": [],
                "labels": []
            }

        input_ids = prompt_ids + summary_ids

        labels = [-100] * len(prompt_ids) + summary_ids

        return {
            "input_ids": input_ids,
            "attention_mask": [1] * len(input_ids),
            "labels": labels
        }

    except Exception:
        return {
            "input_ids": [],
            "attention_mask": [],
            "labels": []
        }
