def load_dialogue_file(path):

    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read().strip()

        # case 1: JSON array
        if text.startswith("["):
            data = json.loads(text)

        # case 2: JSONL
        else:
            data = []
            for line in text.splitlines():
                try:
                    data.append(json.loads(line))
                except:
                    continue

    except Exception:
        print("⚠️ Skipping corrupted file:", path)
        return []

    rows = []

    for item in data:
        if isinstance(item, dict):
            rows.append(item)

    return rows
