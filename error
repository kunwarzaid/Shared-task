def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are an expert clinical summarization evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": 800,
        "employeeId": EMPLOYEE_ID
    }

    try:

        response = requests.post(
            WRAPPER_URL,
            json=payload
        )

        data = response.json()

        return data["choices"][0]["message"]["content"]

    except Exception as e:

        print("GPT call failed:", e)
        return ""
