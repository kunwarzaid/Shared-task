import json
import re
import csv
from pathlib import Path
from collections import Counter, defaultdict
import numpy as np
import torch
from tqdm import tqdm

import evaluate
from bert_score import score as bert_score
from transformers import AutoTokenizer, AutoModelForSequenceClassification

# ============================================================
# CONFIG (edit paths/models as needed)
# ============================================================
TEST_DIR = "/workspace/data/KZ_2117574/SharedTask_NLPAI4Health_Train&dev_set"

MODELS = {
    "Qwen-2.5-7B-finetune": "/workspace/data/KZ_2117574/EACL/Qwen_2.5_7B_Instruct_split/finetune"
}

LANGS = ["English", "Hindi", "Marathi", "Bangla"]

OUTPUT_DIR = Path("/workspace/data/KZ_2117574/EACL/eval_results/qwen_finetune_chunked")
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

# NLI model (multilingual XNLI)
NLI_MODEL = "joeddav/xlm-roberta-large-xnli"
# mapping: many MNLI/XNLI models output logits in order [contradiction, neutral, entailment]
LABEL_ENTAILMENT = 2

# chunking params for long dialogues
CHUNK_SIZE = 480        # tokens per chunk (<=512)
CHUNK_OVERLAP = 64      # overlap in tokens
NLI_BATCH = 8           # inference batch size for NLI
ENTAIL_AGG = "max"      # "max" (recommended) or "mean" or "max_minus_contra"

# evaluation config
BERT_MODEL = "xlm-roberta-large"
N_BOOTSTRAP = 1000
CI_ALPHA = 0.05
DEBUG_PRINT = 6         # print debug for first N examples per language

# ============================================================
# LOAD METRICS / MODELS
# ============================================================
rouge = evaluate.load("rouge")

nli_tokenizer = AutoTokenizer.from_pretrained(NLI_MODEL, use_fast=True)
nli_model = AutoModelForSequenceClassification.from_pretrained(NLI_MODEL).to(DEVICE)
nli_model.eval()

# ============================================================
# UTILITIES
# ============================================================
def safe_read_jsonl(path):
    rows = []
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            try:
                rows.append(json.loads(line))
            except Exception:
                pass
    return rows

def tokenize_words(text):
    return re.findall(r"\b\w+\b", (text or "").lower())

def token_f1(pred, gold):
    p, g = tokenize_words(pred), tokenize_words(gold)
    if not p or not g:
        return 0.0
    pc, gc = Counter(p), Counter(g)
    overlap = sum((pc & gc).values())
    prec = overlap / len(p)
    rec = overlap / len(g)
    return 0.0 if prec + rec == 0 else 2 * prec * rec / (prec + rec)

def bootstrap_ci(scores):
    scores = np.array(scores)
    means = []
    n = len(scores)
    if n == 0:
        return 0.0, 0.0
    for _ in range(N_BOOTSTRAP):
        sample = np.random.choice(scores, n, replace=True)
        means.append(sample.mean())
    low = np.percentile(means, 100 * CI_ALPHA / 2)
    high = np.percentile(means, 100 * (1 - CI_ALPHA / 2))
    return float(low), float(high)

# ============================================================
# NLI: chunking + batched scoring
# ============================================================
def chunk_ids(ids, size=CHUNK_SIZE, overlap=CHUNK_OVERLAP):
    """Return list of lists of token ids (chunked, overlapping)."""
    if len(ids) <= size:
        return [ids]
    step = size - overlap
    chunks = []
    for i in range(0, len(ids), step):
        chunk = ids[i:i+size]
        chunks.append(chunk)
        if i + size >= len(ids):
            break
    return chunks

def compute_entail_probs_for_chunks(chunk_id_list, hypothesis, batch_size=NLI_BATCH):
    """Given list of token-id chunks and hypothesis string, return list of entailment probabilities for each chunk."""
    # decode chunks back to text (fast) and then tokenise as pairs
    chunk_texts = [nli_tokenizer.decode(ids, skip_special_tokens=True) for ids in chunk_id_list]
    pair_texts = list(zip(chunk_texts, [hypothesis] * len(chunk_texts)))

    entail_probs = []
    contra_probs = []  # optionally keep contradiction prob
    for i in range(0, len(pair_texts), batch_size):
        batch = pair_texts[i:i+batch_size]
        lefts = [p for p, h in batch]
        rights = [h for p, h in batch]
        inputs = nli_tokenizer(lefts, rights, padding=True, truncation=True, max_length=512, return_tensors="pt").to(DEVICE)
        with torch.no_grad():
            logits = nli_model(**inputs).logits  # shape [B,3]
            probs = torch.softmax(logits, dim=-1).cpu().numpy()
        # index 2 => entailment, index 0 => contradiction
        entail_probs.extend(probs[:, LABEL_ENTAILMENT].tolist())
        contra_probs.extend(probs[:, 0].tolist())
    return entail_probs, contra_probs

def nli_faithfulness_chunked(source, summary, debug=False):
    """Return a single float faith score (P(entailment) aggregated across chunks).
       Aggregation modes: 'max' (recommended), 'mean', 'max_minus_contra'."""
    # get token ids for the source (no special tokens)
    src_ids = nli_tokenizer.encode(source, add_special_tokens=False)
    chunk_id_list = chunk_ids(src_ids, size=CHUNK_SIZE, overlap=CHUNK_OVERLAP)
    entail_p, contra_p = compute_entail_probs_for_chunks(chunk_id_list, summary)

    if debug:
        print("  SOURCE_TOKENS:", len(src_ids), " num_chunks:", len(chunk_id_list))
        print("  chunk_entail_probs:", [round(x,3) for x in entail_p])

    if ENTAIL_AGG == "max":
        score = float(max(entail_p)) if entail_p else 0.0
    elif ENTAIL_AGG == "mean":
        score = float(np.mean(entail_p)) if entail_p else 0.0
    elif ENTAIL_AGG == "max_minus_contra":
        # pick chunk with max (entail - contra)
        diffs = [e - c for e, c in zip(entail_p, contra_p)]
        idx = int(np.argmax(diffs)) if diffs else 0
        score = float(entail_p[idx]) if entail_p else 0.0
    else:
        score = float(max(entail_p)) if entail_p else 0.0

    return score

# ============================================================
# DATA LOADING
# ============================================================
def load_data(test_root, pred_root, lang):
    sources, preds, golds = [], [], []

    dlg_dir = Path(test_root) / lang / "Dialogues"
    gold_dir = Path(test_root) / lang / "Summary_Text"
    pred_dir = Path(pred_root) / lang / "Summary_Text"

    if not dlg_dir.exists():
        return sources, preds, golds

    for dlg_file in sorted(dlg_dir.glob("*.jsonl")):
        name = dlg_file.stem + "_summary.txt"
        gold_file = gold_dir / name
        pred_file = pred_dir / name
        if not (gold_file.exists() and pred_file.exists()):
            continue

        rows = safe_read_jsonl(dlg_file)
        source = " ".join(r.get("dialogue", "") for r in rows if isinstance(r, dict))
        gold = gold_file.read_text(encoding="utf-8", errors="replace").strip()
        pred = pred_file.read_text(encoding="utf-8", errors="replace").strip()

        if source and gold and pred:
            sources.append(source)
            golds.append(gold)
            preds.append(pred)

    return sources, preds, golds

# ============================================================
# EVALUATION PER LANGUAGE
# ============================================================
def evaluate_language(lang, pred_root):
    sources, preds, golds = load_data(TEST_DIR, pred_root, lang)
    if len(preds) == 0:
        return None

    # ROUGE-L per example
    rouge_scores = rouge.compute(predictions=preds, references=golds, rouge_types=["rougeL"], use_aggregator=False)["rougeL"]
    rouge_scores = np.array(rouge_scores, dtype=float)
    rouge_mean = float(np.mean(rouge_scores))
    rouge_ci = bootstrap_ci(rouge_scores)

    # BERTScore F1
    _, _, bert_f1 = bert_score(preds, golds, model_type=BERT_MODEL, device=DEVICE, lang="xx")
    bert_scores = bert_f1.cpu().numpy()
    bert_mean = float(bert_scores.mean())
    bert_ci = bootstrap_ci(bert_scores)

    # token overlap metric (optional)
    token_scores = [token_f1(p, g) for p, g in zip(preds, golds)]
    token_mean = float(np.mean(token_scores))
    token_ci = bootstrap_ci(token_scores)

    # chunked NLI faithfulness (use debug prints for first DEBUG_PRINT)
    faith_scores = []
    for i, (s, p) in enumerate(tqdm(list(zip(sources, preds)), desc=f"{lang} NLI")):
        debug = (i < DEBUG_PRINT)
        fs = nli_faithfulness_chunked(s, p, debug=debug)
        faith_scores.append(fs)

    faith_scores = np.array(faith_scores, dtype=float)
    faith_mean = float(np.mean(faith_scores))
    faith_ci = bootstrap_ci(faith_scores)

    return {
        "ROUGE-L": (rouge_mean, *rouge_ci),
        "BERTScore": (bert_mean, *bert_ci),
        "TokenF1": (token_mean, *token_ci),
        "Faithfulness": (faith_mean, *faith_ci),
        "N": len(preds)
    }

# ============================================================
# MAIN
# ============================================================
def main():
    results = defaultdict(dict)
    for model_name, path in MODELS.items():
        print("Now Evaluating:", model_name)
        for lang in LANGS:
            print(" Language:", lang)
            scores = evaluate_language(lang, path)
            if scores:
                results[model_name][lang] = scores

    out_json = OUTPUT_DIR / "results_chunked.json"
    with open(out_json, "w", encoding="utf-8") as f:
        json.dump(results, f, indent=2)

    out_csv = OUTPUT_DIR / "results_chunked.csv"
    with open(out_csv, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow(["Model", "Language", "Metric", "Mean", "CI_low", "CI_high", "N"])
        for model in results:
            for lang in results[model]:
                for metric, vals in results[model][lang].items():
                    if metric != "N":
                        writer.writerow([model, lang, metric, *vals, results[model][lang]["N"]])

    print(f"\nSaved results to {OUTPUT_DIR.resolve()}")

if __name__ == "__main__":
    main()
