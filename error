import os
import json
import zipfile
import requests
import pandas as pd
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed

# -------------------------
# CONFIG
# -------------------------

WRAPPER_URL = "https://openai-wrapper-adf0awcrcjghg3cz.southindia-01.azurewebsites.net/openai_service"
MODEL = "gpt-5"
EMPLOYEE_ID = "1757421"

FINETUNE_ZIP = "finetune.zip"
TEST_ZIP = "test.zip"

DATA_DIR = "data_eval"
MAX_TOKENS = 1200

THREADS = 6


# -------------------------
# GPT CALL
# -------------------------

def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are a strict medical summary faithfulness evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": MAX_TOKENS,
        "employeeId": EMPLOYEE_ID
    }

    try:

        r = requests.post(WRAPPER_URL, json=payload, timeout=60)

        return r.json()["choices"][0]["message"]["content"]

    except:
        return ""


# -------------------------
# UNZIP DATA
# -------------------------

def unzip_data():

    os.makedirs(DATA_DIR, exist_ok=True)

    with zipfile.ZipFile(FINETUNE_ZIP, 'r') as z:
        z.extractall(DATA_DIR)

    with zipfile.ZipFile(TEST_ZIP, 'r') as z:
        z.extractall(DATA_DIR)

    print("Data extracted")


# -------------------------
# LOAD DIALOGUE
# -------------------------

def load_dialogue(path):

    lines = []

    with open(path, "r", encoding="utf-8") as f:

        for line in f:

            line = line.strip()

            if not line:
                continue

            try:
                obj = json.loads(line)

                speaker = obj.get("speaker", "")
                text = obj.get("dialogue", "")

                lines.append(f"{speaker}: {text}")

            except:
                continue

    return "\n".join(lines)


# -------------------------
# LOAD SUMMARY
# -------------------------

def load_summary(path):

    with open(path, "r", encoding="utf-8") as f:
        return f.read()


# -------------------------
# BUILD PROMPT
# -------------------------

def build_prompt(dialogue, summary):

    return f"""
Evaluate factual faithfulness of the summary with respect to the dialogue.

Steps:
1 Extract facts from the summary
2 Check if each fact is supported by the dialogue
3 Mark unsupported facts as hallucinated

Dialogue:
{dialogue}

Summary:
{summary}

Return JSON:

{{
 "supported_count": int,
 "hallucinated_count": int,
 "faithfulness_score": float
}}
"""


# -------------------------
# FILE PAIRS
# -------------------------

def collect_pairs():

    pairs = []

    langs = ["English", "Hindi", "Marathi", "Bangla"]

    for lang in langs:

        summary_dir = Path(DATA_DIR) / "finetune" / lang / "Summary_Text"
        dialogue_dir = Path(DATA_DIR) / "test" / lang / "Dialogues"

        if not summary_dir.exists():
            continue

        for s in summary_dir.glob("*_summary.txt"):

            base = s.stem.replace("_summary", "")

            d = dialogue_dir / f"{base}.jsonl"

            if d.exists():

                pairs.append({
                    "language": lang,
                    "summary": s,
                    "dialogue": d
                })

    print("Total pairs found:", len(pairs))

    return pairs


# -------------------------
# EVALUATE
# -------------------------

def evaluate(pair):

    dialogue = load_dialogue(pair["dialogue"])
    summary = load_summary(pair["summary"])

    prompt = build_prompt(dialogue, summary)

    result = call_gpt(prompt)

    try:

        res = json.loads(result)

        return {
            "language": pair["language"],
            "file": pair["summary"].name,
            "supported": res.get("supported_count", 0),
            "hallucinated": res.get("hallucinated_count", 0),
            "faithfulness": res.get("faithfulness_score", 0)
        }

    except:

        return {
            "language": pair["language"],
            "file": pair["summary"].name,
            "supported": 0,
            "hallucinated": 0,
            "faithfulness": 0
        }


# -------------------------
# MAIN
# -------------------------

def run():

    unzip_data()

    pairs = collect_pairs()

    results = []

    with ThreadPoolExecutor(max_workers=THREADS) as executor:

        futures = [executor.submit(evaluate, p) for p in pairs]

        for f in as_completed(futures):

            results.append(f.result())

            print("Completed:", len(results), "/", len(pairs))

    df = pd.DataFrame(results)

    df.to_csv("file_level_results.csv", index=False)

    lang_table = df.groupby("language").agg(
        files=("file", "count"),
        avg_faithfulness=("faithfulness", "mean"),
        hallucinated_total=("hallucinated", "sum")
    ).reset_index()

    lang_table.to_csv("language_summary.csv", index=False)

    print("\nOverall Faithfulness:", round(df["faithfulness"].mean(), 3))


if __name__ == "__main__":
    run()
