def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are an expert clinical summarization evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": 800,
        "employeeId": EMPLOYEE_ID
    }

    try:

        response = requests.post(
            WRAPPER_URL,
            json=payload,
            timeout=120
        )

        data = response.json()

        # handle wrapper formats
        if "response" in data:
            ans = data["response"]

        elif "choices" in data:
            ans = data["choices"][0]["message"]["content"]

        else:
            ans = str(data)

        return ans.strip()

    except Exception as e:

        print("GPT call failed:", e)

        return ""
