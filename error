import os
import json
import zipfile
import requests
import pandas as pd
import re
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed

# -------------------------
# CONFIG
# -------------------------

WRAPPER_URL = "https://openai-wrapper-adf0awcrcjghg3cz.southindia-01.azurewebsites.net/openai_service"
MODEL = "gpt-5"
EMPLOYEE_ID = "1757421"

FINETUNE_ZIP = "finetune.zip"
TEST_ZIP = "test.zip"

DATA_DIR = "data_eval"

MAX_TOKENS = 1000
THREADS = 6


# -------------------------
# GPT CALL
# -------------------------

def call_gpt(prompt):

    payload = {
        "model": MODEL,
        "prompt": [
            {"role": "system", "content": "You are a strict clinical summarization faithfulness evaluator."},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": MAX_TOKENS,
        "employeeId": EMPLOYEE_ID
    }

    try:

        r = requests.post(WRAPPER_URL, json=payload, timeout=60)

        return r.text

    except Exception as e:

        print("GPT call failed:", e)

        return ""


# -------------------------
# JSON EXTRACTOR
# -------------------------

def extract_json(text):

    try:
        return json.loads(text)
    except:
        pass

    match = re.search(r'\{.*\}', text, re.DOTALL)

    if match:
        try:
            return json.loads(match.group())
        except:
            pass

    return None


# -------------------------
# UNZIP DATA
# -------------------------

def unzip_data():

    os.makedirs(DATA_DIR, exist_ok=True)

    with zipfile.ZipFile(FINETUNE_ZIP) as z:
        z.extractall(DATA_DIR)

    with zipfile.ZipFile(TEST_ZIP) as z:
        z.extractall(DATA_DIR)

    print("Data extracted")


# -------------------------
# LOAD DIALOGUE
# -------------------------

def load_dialogue(path):

    lines = []

    with open(path, encoding="utf-8") as f:

        for line in f:

            line = line.strip()

            if not line:
                continue

            try:

                obj = json.loads(line)

                speaker = obj.get("speaker", "")
                text = obj.get("dialogue", "")

                lines.append(f"{speaker}: {text}")

            except:
                continue

    return "\n".join(lines)


# -------------------------
# LOAD SUMMARY
# -------------------------

def load_summary(path):

    with open(path, encoding="utf-8") as f:
        return f.read()


# -------------------------
# PROMPT
# -------------------------

def build_prompt(dialogue, summary):

    return f"""
Evaluate factual faithfulness of the summary with respect to the dialogue.

Steps:

1 Extract facts from the summary
2 Check whether each fact appears in the dialogue
3 Unsupported facts are hallucinations

Dialogue:
{dialogue}

Summary:
{summary}

Return JSON ONLY:

{{
 "supported_count": number,
 "hallucinated_count": number,
 "faithfulness_score": number
}}
"""


# -------------------------
# FILE MATCHING
# -------------------------

def collect_pairs():

    pairs = []

    langs = ["English","Hindi","Marathi","Bangla"]

    for lang in langs:

        summary_dir = Path(DATA_DIR)/"finetune"/lang/"Summary_Text"
        dialogue_dir = Path(DATA_DIR)/"test"/lang/"Dialogues"

        if not summary_dir.exists():
            continue

        for s in summary_dir.glob("*_summary.txt"):

            base = s.stem.replace("_summary","")

            d = dialogue_dir / f"{base}.jsonl"

            if d.exists():

                pairs.append({
                    "language":lang,
                    "summary":s,
                    "dialogue":d
                })

    print("Total pairs found:", len(pairs))

    return pairs


# -------------------------
# EVALUATION
# -------------------------

def evaluate(pair, debug=False):

    dialogue = load_dialogue(pair["dialogue"])
    summary = load_summary(pair["summary"])

    prompt = build_prompt(dialogue, summary)

    raw = call_gpt(prompt)

    parsed = extract_json(raw)

    if debug:

        print("\n==========================")
        print("DEBUG SCENARIO")
        print("File:", pair["summary"].name)
        print("\nGPT RAW RESPONSE:\n", raw[:800])
        print("==========================\n")

    if parsed:

        return {
            "language": pair["language"],
            "file": pair["summary"].name,
            "supported": parsed.get("supported_count",0),
            "hallucinated": parsed.get("hallucinated_count",0),
            "faithfulness": parsed.get("faithfulness_score",0)
        }

    return {
        "language": pair["language"],
        "file": pair["summary"].name,
        "supported": 0,
        "hallucinated": 0,
        "faithfulness": 0
    }


# -------------------------
# MAIN
# -------------------------

def run():

    unzip_data()

    pairs = collect_pairs()

    results = []

    with ThreadPoolExecutor(max_workers=THREADS) as executor:

        futures = []

        for i,p in enumerate(pairs):

            debug = True if i < 3 else False

            futures.append(
                executor.submit(evaluate, p, debug)
            )

        for i,f in enumerate(as_completed(futures)):

            results.append(f.result())

            print("Completed:", len(results), "/", len(pairs))

    df = pd.DataFrame(results)

    df.to_csv("file_level_results.csv",index=False)

    lang_table = df.groupby("language").agg(
        files=("file","count"),
        avg_faithfulness=("faithfulness","mean"),
        hallucinated_total=("hallucinated","sum")
    ).reset_index()

    lang_table.to_csv("language_summary.csv",index=False)

    print("\nOverall Faithfulness:", round(df["faithfulness"].mean(),3))


if __name__ == "__main__":
    run()
